---
import MarketOverviewChildTemplate from "../../components/MarketOverviewChildTemplate.astro";
import { getEntryByCanonicalPath } from "../../utils/contentCollections";

const canonicalPath = "/market-overview/market-drivers";
const entry = await getEntryByCanonicalPath("marketOverview", canonicalPath);
const { Content } = await entry.render();
---

<MarketOverviewChildTemplate
  canonicalPath={canonicalPath}
  title={entry.data.title}
  summary={entry.data.summary}
>
  <Content />
</MarketOverviewChildTemplate>
