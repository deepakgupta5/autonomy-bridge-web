---
import DetailPageTemplate from "../../components/DetailPageTemplate.astro";
import { useCaseSlugs } from "../../data/ia";
import { getEntryByCanonicalPath } from "../../utils/contentCollections";
import { extractFaqItemsFromMarkdown } from "../../utils/faq";

export function getStaticPaths() {
  return useCaseSlugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const canonicalPath = `/use-cases/${slug}`;
const entry = await getEntryByCanonicalPath("useCases", canonicalPath);
const { Content } = await entry.render();
const faqItems = extractFaqItemsFromMarkdown(entry.body);
---

<DetailPageTemplate
  canonicalPath={canonicalPath}
  title={entry.data.title}
  summary={entry.data.summary}
  contentTypeLabel="Use Case"
  schemaKind="useCase"
  slug={slug}
  hubPath="/use-cases"
  hubLabel="Use Cases"
  datePublished={String(entry.data.datePublished)}
  dateModified={String(entry.data.dateModified)}
  authors={entry.data.authors}
  faqItems={faqItems}
>
  <Content />
</DetailPageTemplate>
