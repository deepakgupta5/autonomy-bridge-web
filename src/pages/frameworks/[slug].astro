---
import Layout from "../../components/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  const frameworks = await getCollection("frameworks");
  return frameworks.map((fw) => ({
    params: { slug: fw.slug },
    props: { fw },
  }));
}

const { fw } = Astro.props;
const { Content } = await fw.render();

const {
  title,
  description,
  diagramFile,
  diagramFiles,
  relatedArticles,
  relatedUseCases,
  relatedCaseStudies,
} = fw.data;

const allDiagrams = diagramFiles ?? (diagramFile ? [diagramFile] : []);

const allArticles = relatedArticles
  ? await Promise.all(
      relatedArticles.map(async (slug: string) => {
        try {
          const entry = await getEntry("articles", slug);
          return entry ? { title: entry.data.title, slug } : null;
        } catch {
          return null;
        }
      })
    ).then((r) => r.filter(Boolean))
  : [];

const allUseCases = relatedUseCases
  ? await Promise.all(
      relatedUseCases.map(async (slug: string) => {
        try {
          const entry = await getEntry("use-cases", slug);
          return entry ? { title: entry.data.title, slug } : null;
        } catch {
          return null;
        }
      })
    ).then((r) => r.filter(Boolean))
  : [];

const allCaseStudies = relatedCaseStudies
  ? await Promise.all(
      relatedCaseStudies.map(async (slug: string) => {
        try {
          const entry = await getEntry("case-studies", slug);
          return entry ? { title: entry.data.title, slug } : null;
        } catch {
          return null;
        }
      })
    ).then((r) => r.filter(Boolean))
  : [];

const breadcrumbs = [
  { name: "Home", url: "https://www.autonomybridge.com/" },
  { name: "Frameworks", url: "https://www.autonomybridge.com/frameworks" },
  { name: title, url: `https://www.autonomybridge.com/frameworks/${fw.slug}` },
];
---

<Layout
  title={`${title} — Frameworks — Autonomy Bridge`}
  description={description}
  canonicalPath={`/frameworks/${fw.slug}`}
  breadcrumbs={breadcrumbs}
>
  <Header />

  <main class="container site-main">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb__separator" aria-hidden="true">›</span>
      <a href="/frameworks">Frameworks</a>
      <span class="breadcrumb__separator" aria-hidden="true">›</span>
      <span>{title}</span>
    </nav>

    <h1 class="reading-column">{title}</h1>

    {allDiagrams.map((src: string, i: number) => (
      <figure class="framework-diagram reading-column">
        <img src={src} alt={`${title} diagram ${allDiagrams.length > 1 ? i + 1 : ''}`} loading={i === 0 ? "eager" : "lazy"} />
        {allDiagrams.length > 1 && (
          <figcaption>Figure {i + 1} of {allDiagrams.length}</figcaption>
        )}
      </figure>
    ))}

    <article class="reading-column prose">
      <Content />
    </article>

    <div class="reading-column article-cta">
      <h2>Apply this framework to your deployment decision</h2>
      <p>
        If you need this framework applied to a specific facility, vendor
        proposal, or investment, a structured Decision Brief produces a clear
        Go / Pause / Kill recommendation based on your operational data.
      </p>
      <a href="/advisory" class="btn-primary">Request a Decision Brief</a>
    </div>

    <div class="reading-column">
      <InternalLinks
        relatedArticles={allArticles as any}
        relatedUseCases={allUseCases as any}
        relatedCaseStudies={allCaseStudies as any}
      />
    </div>
  </main>

  <Footer />
</Layout>
