---
import DetailPageTemplate from "../../components/DetailPageTemplate.astro";
import { frameworkSlugs } from "../../data/ia";
import { getFrameworkDiagrams } from "../../data/diagramAssetMap";
import { getEntryByCanonicalPath } from "../../utils/contentCollections";
import { extractFaqItemsFromMarkdown } from "../../utils/faq";

export function getStaticPaths() {
  return frameworkSlugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const canonicalPath = `/frameworks/${slug}`;
const entry = await getEntryByCanonicalPath("frameworks", canonicalPath);
const { Content } = await entry.render();
const diagrams = getFrameworkDiagrams(slug);
const faqItems = extractFaqItemsFromMarkdown(entry.body);
---

<DetailPageTemplate
  canonicalPath={canonicalPath}
  title={entry.data.title}
  summary={entry.data.summary}
  contentTypeLabel="Framework"
  schemaKind="framework"
  slug={slug}
  hubPath="/frameworks"
  hubLabel="Frameworks"
  diagrams={diagrams}
  datePublished={String(entry.data.datePublished)}
  dateModified={String(entry.data.dateModified)}
  authors={entry.data.authors}
  faqItems={faqItems}
>
  <Content />
</DetailPageTemplate>
