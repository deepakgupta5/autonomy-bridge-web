---
import HubPageTemplate from "../../components/HubPageTemplate.astro";
import { getEntryByCanonicalPath, getEntriesByCanonicalPrefix } from "../../utils/contentCollections";
import { extractFaqItemsFromMarkdown } from "../../utils/faq";

const hubEntry = await getEntryByCanonicalPath("frameworks", "/frameworks");
const detailEntries = await getEntriesByCanonicalPrefix("frameworks", "/frameworks", {
  excludeCanonicalPaths: ["/frameworks"],
});
const { Content } = await hubEntry.render();
const faqItems = extractFaqItemsFromMarkdown(hubEntry.body);

const frameworksHubContent = {
  title: hubEntry.data.title,
  summary: hubEntry.data.summary,
  intro: hubEntry.data.description,
  emptyState: "No framework entries are available.",
  items: detailEntries.map((entry) => ({
    title: entry.data.title,
    href: entry.data.canonicalPath,
    description: entry.data.summary,
    metadata: [`Published: ${String(entry.data.datePublished)}`],
    taxonomy: Array.from(
      new Set([
        ...entry.data.frameworks,
        ...entry.data.topics,
        ...entry.data.technologies,
        ...entry.data.industries,
      ])
    ),
  })),
};
---

<HubPageTemplate canonicalPath="/frameworks" content={frameworksHubContent} faqItems={faqItems}>
  <Content />
</HubPageTemplate>
