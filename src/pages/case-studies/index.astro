---
import HubPageTemplate from "../../components/HubPageTemplate.astro";
import type { HubPageContent } from "../../data/hubContent";
import { caseStudySlugs } from "../../data/ia";
import {
  getEntriesByCanonicalPrefix,
  getEntryByCanonicalPath,
} from "../../utils/contentCollections";

const hubCanonicalPath = "/case-studies";
const hubEntry = await getEntryByCanonicalPath("caseStudies", hubCanonicalPath);
const detailEntries = await getEntriesByCanonicalPrefix("caseStudies", `${hubCanonicalPath}/`, {
  includeExact: false,
});

const detailBySlug = new Map(detailEntries.map((entry) => [entry.data.slug, entry]));
const items: HubPageContent["items"] = caseStudySlugs.flatMap((slug) => {
  const entry = detailBySlug.get(slug);
  if (!entry) {
    return [];
  }

  return [
    {
      title: entry.data.title,
      href: entry.data.canonicalPath,
      description: entry.data.description,
      metadata: [`Updated: ${String(entry.data.dateModified)}`],
      taxonomy: entry.data.topics.length > 0 ? entry.data.topics : ["case-studies"],
    },
  ];
});

const content: HubPageContent = {
  title: hubEntry.data.title,
  summary: hubEntry.data.summary,
  intro: hubEntry.data.description,
  emptyState: "No case studies are available yet.",
  items,
};

const { Content } = await hubEntry.render();
---

<HubPageTemplate canonicalPath={hubCanonicalPath} content={content}>
  <Content />
</HubPageTemplate>
