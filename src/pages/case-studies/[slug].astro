---
import Layout from "../../components/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import InternalLinks from "../../components/InternalLinks.astro";
import { getCollection, getEntry } from "astro:content";

export async function getStaticPaths() {
  const caseStudies = await getCollection("case-studies");
  return caseStudies.map((cs) => ({
    params: { slug: cs.slug },
    props: { cs },
  }));
}

const { cs } = Astro.props;
const { Content } = await cs.render();

const { title, description, relatedArticles, relatedFrameworks } = cs.data;

const allArticles = relatedArticles
  ? await Promise.all(
      relatedArticles.map(async (slug: string) => {
        try {
          const entry = await getEntry("articles", slug);
          return entry ? { title: entry.data.title, slug } : null;
        } catch { return null; }
      })
    ).then((r) => r.filter(Boolean))
  : [];

const allFrameworks = relatedFrameworks
  ? await Promise.all(
      relatedFrameworks.map(async (slug: string) => {
        try {
          const entry = await getEntry("frameworks", slug);
          return entry ? { title: entry.data.title, slug } : null;
        } catch { return null; }
      })
    ).then((r) => r.filter(Boolean))
  : [];

const breadcrumbs = [
  { name: "Home", url: "https://www.autonomybridge.com/" },
  { name: "Case Studies", url: "https://www.autonomybridge.com/case-studies" },
  { name: title, url: `https://www.autonomybridge.com/case-studies/${cs.slug}` },
];
---

<Layout
  title={`${title} — Case Studies — Autonomy Bridge`}
  description={description}
  canonicalPath={`/case-studies/${cs.slug}`}
  breadcrumbs={breadcrumbs}
>
  <Header />

  <main class="container site-main">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb__separator" aria-hidden="true">›</span>
      <a href="/case-studies">Case Studies</a>
      <span class="breadcrumb__separator" aria-hidden="true">›</span>
      <span>{title}</span>
    </nav>

    <h1 class="reading-column">{title}</h1>
    <p class="subhead reading-column">{description}</p>

    <article class="reading-column prose">
      <Content />
    </article>

    <div class="reading-column">
      <InternalLinks
        relatedArticles={allArticles as any}
        relatedFrameworks={allFrameworks as any}
      />
    </div>
  </main>

  <Footer />
</Layout>
