---
import DetailPageTemplate from "../../components/DetailPageTemplate.astro";
import { caseStudySlugs } from "../../data/ia";
import { getEntryByCanonicalPath } from "../../utils/contentCollections";
import { extractFaqItemsFromMarkdown } from "../../utils/faq";

export function getStaticPaths() {
  return caseStudySlugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const canonicalPath = `/case-studies/${slug}`;
const entry = await getEntryByCanonicalPath("caseStudies", canonicalPath);
const { Content } = await entry.render();
const faqItems = extractFaqItemsFromMarkdown(entry.body);
---

<DetailPageTemplate
  canonicalPath={canonicalPath}
  title={entry.data.title}
  summary={entry.data.summary}
  contentTypeLabel="Case Study"
  schemaKind="caseStudy"
  slug={slug}
  hubPath="/case-studies"
  hubLabel="Case Studies"
  datePublished={String(entry.data.datePublished)}
  dateModified={String(entry.data.dateModified)}
  authors={entry.data.authors}
  faqItems={faqItems}
>
  <Content />
</DetailPageTemplate>
