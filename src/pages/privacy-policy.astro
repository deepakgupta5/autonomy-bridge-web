---
import MainLayout from "../components/MainLayout.astro";

const canonicalPath = "/privacy-policy";
const title = "Privacy Policy";
const summary = "How Autonomy Bridge collects, uses, and protects your data.";
---

<MainLayout
  canonicalPath={canonicalPath}
  title={title}
  summary={summary}
  seoTitle="Privacy Policy | Autonomy Bridge"
>
  <article class="policy-page">
    <h1 class="type-h1">Privacy Policy</h1>
    <p class="policy-meta">
      Last updated: March 15, 2026<br />
      Applies to users in Canada and the United States
    </p>

    <section>
      <h2 class="type-h2">Overview</h2>
      <p>Autonomy Bridge is a B2B research and advisory firm.</p>
      <p>We do not operate user accounts, process payments, or run advertising systems.</p>
      <p>This policy explains:</p>
      <ul>
        <li>what data we collect</li>
        <li>what we do not collect</li>
        <li>how limited data is used</li>
        <li>how long it is retained</li>
      </ul>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Data We Collect</h2>

      <h3 class="type-h3">Contact form data</h3>
      <p>When you submit a contact form, we receive:</p>
      <ul>
        <li>Name</li>
        <li>Email address</li>
        <li>Message content</li>
      </ul>
      <p>
        This data is processed through Netlify Forms and used only to respond to your inquiry.
      </p>

      <h3 class="type-h3">Analytics data</h3>
      <p>
        We use a privacy-first analytics tool (such as Plausible) to understand aggregate site
        usage, including:
      </p>
      <ul>
        <li>Page views</li>
        <li>Referral sources</li>
        <li>Approximate geography</li>
      </ul>
      <p>
        This data is anonymized. No personal identifiers are collected. No cookies are set by the
        analytics tool.
      </p>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Data We Do Not Collect</h2>
      <ul>
        <li>User accounts or authentication data</li>
        <li>Payment or billing information</li>
        <li>Advertising or tracking identifiers</li>
        <li>Cross-site behavioral profiles</li>
        <li>Data from children</li>
      </ul>
      <p>The site is intended for business professionals.</p>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Permitted Use of Data</h2>
      <p>We use collected data only for:</p>
      <ul>
        <li>Responding to contact form inquiries</li>
        <li>Understanding aggregate site usage</li>
      </ul>
      <p>We do not use data for:</p>
      <ul>
        <li>Marketing campaigns</li>
        <li>Personalization</li>
        <li>Advertising</li>
        <li>Sale or sharing with third parties</li>
      </ul>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Data Retention</h2>
      <ul>
        <li>Contact form submissions are retained for up to 12 months, then deleted</li>
        <li>Analytics data is retained only in aggregated, non-identifiable form</li>
      </ul>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Third-Party Services</h2>
      <p>We use:</p>
      <ul>
        <li>Netlify (hosting and form processing)</li>
        <li>Privacy-first analytics provider (e.g. Plausible)</li>
      </ul>
      <p>These providers process data only as required to operate the site.</p>
      <p>We do not use:</p>
      <ul>
        <li>Advertising networks</li>
        <li>Marketing automation platforms</li>
        <li>Data brokers</li>
      </ul>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Your Rights (Canada &amp; United States)</h2>
      <p>Depending on your jurisdiction, you may have the right to:</p>
      <ul>
        <li>Request access to your data</li>
        <li>Request correction or deletion</li>
        <li>Understand how your data is used</li>
      </ul>
      <p>Requests can be submitted through the contact page.</p>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Policy Updates</h2>
      <p>This policy is updated when data practices change.</p>
      <p>
        The current version is indicated by the &ldquo;Last updated&rdquo; date above.
      </p>
    </section>
  </article>
</MainLayout>

<style>
  .policy-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .policy-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0.75rem 0 2rem;
    line-height: 1.6;
  }

  .policy-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border-light);
  }

  .policy-page :global(h2) {
    margin-bottom: 1rem;
  }

  .policy-page :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .policy-page p + p {
    margin-top: 1rem;
  }

  .policy-page ul {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .policy-page ul + p {
    margin-top: 1rem;
  }

  .policy-page li + li {
    margin-top: 0.4rem;
  }

  .policy-page a {
    color: var(--color-link);
    text-underline-offset: 0.14rem;
  }
</style>
