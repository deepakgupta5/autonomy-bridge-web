---
import MainLayout from "../components/MainLayout.astro";

const canonicalPath = "/privacy-policy";
const title = "Privacy Policy";
const summary = "How Autonomy Bridge collects, uses, and protects your data.";
---

<MainLayout
  canonicalPath={canonicalPath}
  title={title}
  summary={summary}
  seoTitle="Privacy Policy | Autonomy Bridge"
>
  <article class="max-w-[720px] mx-auto px-6 py-12 md:py-16">
    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4">Privacy Policy</h1>
    <p class="text-sm text-gray-500 mb-8">
      Last updated: March 15, 2026<br />
      Applies to users in Canada and the United States
    </p>

    <section>
      <h2 class="text-2xl md:text-3xl font-semibold mt-12 mb-4">Overview</h2>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        Autonomy Bridge is a B2B research and advisory firm.
      </p>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        We do not operate user accounts, process payments, or run advertising systems.
      </p>
      <p class="text-base leading-relaxed text-gray-800 mb-4">This policy explains:</p>
      <ul class="list-disc pl-5 space-y-2 text-base leading-relaxed text-gray-800 mb-4">
        <li>what data we collect</li>
        <li>what we do not collect</li>
        <li>how limited data is used</li>
        <li>how long it is retained</li>
      </ul>
    </section>

    <section class="mt-12 border-t border-gray-200 pt-8">
      <h2 class="text-2xl md:text-3xl font-semibold mt-12 mb-4">Data We Collect</h2>

      <h3 class="text-lg font-semibold mt-6 mb-2">Contact form data</h3>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        When you submit a contact form, we receive:
      </p>
      <ul class="list-disc pl-5 space-y-2 text-base leading-relaxed text-gray-800 mb-4">
        <li>Name</li>
        <li>Email address</li>
        <li>Message content</li>
      </ul>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        This data is processed through Netlify Forms and used only to respond to your inquiry.
      </p>

      <h3 class="text-lg font-semibold mt-6 mb-2">Analytics data</h3>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        We use a privacy-first analytics tool (such as Plausible) to understand aggregate site
        usage, including:
      </p>
      <ul class="list-disc pl-5 space-y-2 text-base leading-relaxed text-gray-800 mb-4">
        <li>Page views</li>
        <li>Referral sources</li>
        <li>Approximate geography</li>
      </ul>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        This data is anonymized. No personal identifiers are collected. No cookies are set by the
        analytics tool.
      </p>
    </section>

    <section class="mt-12 border-t border-gray-200 pt-8">
      <h2 class="text-2xl md:text-3xl font-semibold mt-12 mb-4">Data We Do Not Collect</h2>
      <ul class="list-disc pl-5 space-y-2 text-base leading-relaxed text-gray-800 mb-4">
        <li>User accounts or authentication data</li>
        <li>Payment or billing information</li>
        <li>Advertising or tracking identifiers</li>
        <li>Cross-site behavioral profiles</li>
        <li>Data from children</li>
      </ul>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        The site is intended for business professionals.
      </p>
    </section>

    <section class="mt-12 border-t border-gray-200 pt-8">
      <h2 class="text-2xl md:text-3xl font-semibold mt-12 mb-4">Permitted Use of Data</h2>
      <p class="text-base leading-relaxed text-gray-800 mb-4">We use collected data only for:</p>
      <ul class="list-disc pl-5 space-y-2 text-base leading-relaxed text-gray-800 mb-4">
        <li>Responding to contact form inquiries</li>
        <li>Understanding aggregate site usage</li>
      </ul>
      <p class="text-base leading-relaxed text-gray-800 mb-4">We do not use data for:</p>
      <ul class="list-disc pl-5 space-y-2 text-base leading-relaxed text-gray-800 mb-4">
        <li>Marketing campaigns</li>
        <li>Personalization</li>
        <li>Advertising</li>
        <li>Sale or sharing with third parties</li>
      </ul>
    </section>

    <section class="mt-12 border-t border-gray-200 pt-8">
      <h2 class="text-2xl md:text-3xl font-semibold mt-12 mb-4">Data Retention</h2>
      <ul class="list-disc pl-5 space-y-2 text-base leading-relaxed text-gray-800 mb-4">
        <li>Contact form submissions are retained for up to 12 months, then deleted</li>
        <li>Analytics data is retained only in aggregated, non-identifiable form</li>
      </ul>
    </section>

    <section class="mt-12 border-t border-gray-200 pt-8">
      <h2 class="text-2xl md:text-3xl font-semibold mt-12 mb-4">Third-Party Services</h2>
      <p class="text-base leading-relaxed text-gray-800 mb-4">We use:</p>
      <ul class="list-disc pl-5 space-y-2 text-base leading-relaxed text-gray-800 mb-4">
        <li>Netlify (hosting and form processing)</li>
        <li>Privacy-first analytics provider (e.g. Plausible)</li>
      </ul>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        These providers process data only as required to operate the site.
      </p>
      <p class="text-base leading-relaxed text-gray-800 mb-4">We do not use:</p>
      <ul class="list-disc pl-5 space-y-2 text-base leading-relaxed text-gray-800 mb-4">
        <li>Advertising networks</li>
        <li>Marketing automation platforms</li>
        <li>Data brokers</li>
      </ul>
    </section>

    <section class="mt-12 border-t border-gray-200 pt-8">
      <h2 class="text-2xl md:text-3xl font-semibold mt-12 mb-4">
        Your Rights (Canada &amp; United States)
      </h2>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        Depending on your jurisdiction, you may have the right to:
      </p>
      <ul class="list-disc pl-5 space-y-2 text-base leading-relaxed text-gray-800 mb-4">
        <li>Request access to your data</li>
        <li>Request correction or deletion</li>
        <li>Understand how your data is used</li>
      </ul>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        Requests can be submitted through the contact page.
      </p>
    </section>

    <section class="mt-12 border-t border-gray-200 pt-8">
      <h2 class="text-2xl md:text-3xl font-semibold mt-12 mb-4">Policy Updates</h2>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        This policy is updated when data practices change.
      </p>
      <p class="text-base leading-relaxed text-gray-800 mb-4">
        The current version is indicated by the &ldquo;Last updated&rdquo; date above.
      </p>
    </section>
  </article>
</MainLayout>
