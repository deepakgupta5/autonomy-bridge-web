---
import StaticPageTemplate from "../components/StaticPageTemplate.astro";
import { getEntryByCanonicalPath } from "../utils/contentCollections";

const canonicalPath = "/contact";
const entry = await getEntryByCanonicalPath("pages", canonicalPath);
const { Content } = await entry.render();
---

<StaticPageTemplate
  canonicalPath={canonicalPath}
  title={entry.data.title}
  summary={entry.data.summary}
  schemaKind="contact"
>
  <Content />
</StaticPageTemplate>
