---
import Layout from "../components/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Contact — Autonomy Bridge"
  description="Get in touch with Autonomy Bridge to discuss a research engagement."
>
  <Header />

  <main class="container">
    <h1>Contact</h1>
    <p class="subhead">
      If you have a decision in front of you and need independent research to make it,
      describe it briefly below.
    </p>

    <section class="contact-section">
      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/thank-you"
      >
        <!-- Netlify hidden fields -->
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

        <div class="field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required autocomplete="name" />
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>

        <div class="field">
          <label for="company">Company <span class="optional">(optional)</span></label>
          <input type="text" id="company" name="company" autocomplete="organization" />
        </div>

        <div class="field">
          <label for="message">What decision are you trying to make?</label>
          <textarea id="message" name="message" rows="5" required></textarea>
        </div>

        <button type="submit" class="submit-btn">Send</button>
      </form>
    </section>

    <section class="contact-direct">
      <p>Or email directly: <a href="mailto:deepak@autonomybridge.com">deepak@autonomybridge.com</a></p>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .contact-section {
    max-width: 560px;
    margin-bottom: 3rem;
    border-top: 1px solid var(--border);
    padding-top: 3rem;
  }

  .hidden { display: none; }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  label {
    font-size: 0.875rem;
    color: var(--text-secondary);
    font-family: "Inter", sans-serif;
  }

  .optional {
    color: var(--text-secondary);
    opacity: 0.6;
  }

  input, textarea {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    color: var(--text-primary);
    font-family: "Inter", sans-serif;
    font-size: 0.95rem;
    padding: 0.65rem 0.85rem;
    border-radius: 3px;
    width: 100%;
    outline: none;
    transition: border-color 0.15s ease;
  }

  input:focus, textarea:focus {
    border-color: var(--accent);
  }

  textarea {
    resize: vertical;
    line-height: 1.6;
  }

  .submit-btn {
    background: var(--accent);
    color: var(--text-primary);
    border: none;
    padding: 0.65rem 1.5rem;
    font-family: "Inter", sans-serif;
    font-size: 0.9rem;
    border-radius: 3px;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .submit-btn:hover {
    background: #4a7eb5;
  }

  .contact-direct {
    border-top: 1px solid var(--border);
    padding-top: 2rem;
    max-width: 560px;
  }

  .contact-direct p {
    font-size: 0.9rem;
  }

  .contact-direct a {
    color: var(--accent);
  }

  .contact-direct a:hover {
    color: var(--text-primary);
  }
</style>
