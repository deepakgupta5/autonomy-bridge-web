---
import Layout from "../components/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { renderMarkdown } from "../utils/markdownToHtml";
import methodologyMarkdown from "../content/page-copy/methodology.md?raw";

const breadcrumbs = [
  { name: "Home", url: "https://www.autonomybridge.com/" },
  { name: "Methodology", url: "https://www.autonomybridge.com/methodology" },
];

const methodologyHtml = await renderMarkdown(methodologyMarkdown);
---

<Layout
  title="Methodology — Autonomy Bridge"
  description="Autonomy Bridge methodology for warehouse automation analysis — utilization-first modelling, workflow constraint mapping, and structured decision brief output."
  canonicalPath="/methodology"
  breadcrumbs={breadcrumbs}
>
  <Header />

  <main class="container site-main">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb__separator" aria-hidden="true">›</span>
      <span>Methodology</span>
    </nav>
    <article class="reading-column prose" set:html={methodologyHtml} />
  </main>

  <Footer />
</Layout>
