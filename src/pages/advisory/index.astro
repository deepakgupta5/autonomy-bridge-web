---
import Layout from "../../components/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { renderMarkdown } from "../../utils/markdownToHtml";
import advisoryMarkdown from "../../content/page-copy/advisory.md?raw";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "AMR Deployment Decision Brief",
  provider: {
    "@type": "Organization",
    name: "Autonomy Bridge",
    url: "https://www.autonomybridge.com/",
  },
  serviceType: "Advisory",
  description:
    "Decision-grade research for warehouse operators evaluating autonomous mobile robots. Covers deployment economics, vendor evaluation, utilization modelling, and risk assessment.",
  url: "https://www.autonomybridge.com/advisory",
  areaServed: "Worldwide",
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Advisory Engagements",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "AMR Deployment Decision Brief",
          description:
            "A structured decision document covering deployment economics, vendor evaluation, utilization break-even, and a Go/Pause/Kill recommendation for warehouse AMR investments.",
        },
      },
    ],
  },
};

const breadcrumbs = [
  { name: "Home", url: "https://www.autonomybridge.com/" },
  { name: "Advisory", url: "https://www.autonomybridge.com/advisory" },
];

const advisoryHtml = await renderMarkdown(advisoryMarkdown);
---

<Layout
  title="AMR Deployment Decision Brief — Autonomy Bridge"
  description="Decision-grade research for warehouse operators evaluating autonomous mobile robots. Deployment economics, vendor evaluation, and utilization modelling for AMR investment decisions."
  canonicalPath="/advisory"
  serviceSchema={serviceSchema}
  breadcrumbs={breadcrumbs}
>
  <Header />

  <main class="container site-main advisory-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb__separator" aria-hidden="true">›</span>
      <span>Advisory</span>
    </nav>
    <article class="reading-column prose" set:html={advisoryHtml} />
  </main>

  <Footer />
</Layout>
