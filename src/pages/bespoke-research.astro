---
import MainLayout from "../components/MainLayout.astro";

const canonicalPath = "/bespoke-research";
const title = "Bespoke Research";
const summary = "Custom research built for a defined decision problem in automation, robotics, and industrial AI.";
---

<MainLayout canonicalPath={canonicalPath} title={title} summary={summary} seoTitle="Bespoke Research | Autonomy Bridge">
  <article class="br-page">

    <!-- HEADER -->
    <header class="br-header">
      <div class="br-container">
        <h1 class="br-h1">Bespoke Research</h1>
        <p class="br-tagline">Custom research for a defined decision problem in automation, robotics, and industrial AI</p>
        <p class="br-intro">A bespoke research engagement produces one decision-grade output for one defined problem. This is not a literature review, generic market report, or recycled category summary. It is structured research built for a specific deployment question, investment thesis, market-entry decision, or vendor evaluation problem.</p>
        <div class="br-header-links">
          <a href="/advisory">Advisory →</a>
          <a href="/case-studies">Case Studies →</a>
          <a href="/methodology">Methodology →</a>
        </div>
      </div>
    </header>

    <!-- RESEARCH TYPES -->
    <section class="br-section">
      <div class="br-container">
        <h2 class="br-h2">Research Types</h2>
        <div class="br-types-grid">
          <div class="br-type-card">
            <h3 class="br-type-name">Market Entry Analysis</h3>
            <p>Assessment of addressable opportunity, competitive density, entry constraint, and segment sequencing for a defined automation or industrial AI market.</p>
          </div>
          <div class="br-type-card">
            <h3 class="br-type-name">Vendor Economics Assessment</h3>
            <p>Bottom-up analysis of pricing architecture, unit economics, and margin sustainability across a competitive set of automation platforms or vendors.</p>
          </div>
          <div class="br-type-card">
            <h3 class="br-type-name">Deployment Risk Report</h3>
            <p>Diagnostic of operational, integration, and financial failure modes in a specific automation scenario — mapped against throughput constraints and capital recovery conditions.</p>
          </div>
          <div class="br-type-card">
            <h3 class="br-type-name">Automation ROI Model</h3>
            <p>Structured financial model mapping labor displacement, throughput change, integration cost, and payback under operator-specific assumptions and utilization profiles.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHO COMMISSIONS -->
    <section class="br-section br-section--surface">
      <div class="br-container">
        <h2 class="br-h2">Who Commissions This</h2>
        <div class="br-who-grid">
          <div class="br-who-item">
            <span class="br-who-label">Warehouse &amp; 3PL Operators</span>
            <p>Evaluating vendor proposals, validating pilot economics, or building the case for a capital deployment decision.</p>
          </div>
          <div class="br-who-item">
            <span class="br-who-label">PE &amp; Infrastructure Investors</span>
            <p>Conducting diligence on a robotics company, automation vendor, or logistics infrastructure asset — stress-testing unit economics and market assumptions.</p>
          </div>
          <div class="br-who-item">
            <span class="br-who-label">Robotics &amp; Automation Vendors</span>
            <p>Entering a new segment or vertical and needing buyer-side market intelligence to position effectively and shorten the sales cycle.</p>
          </div>
        </div>
        <p class="br-who-note">The common requirement is the same: a decision needs a tighter analytical basis than vendor material or surface-level market content can provide.</p>
      </div>
    </section>

    <!-- WHAT YOU GET -->
    <section class="br-section">
      <div class="br-container">
        <h2 class="br-h2">What You Get</h2>
        <ul class="br-deliverables">
          <li><span class="br-check">✓</span> A formal structured research document scoped to your decision</li>
          <li><span class="br-check">✓</span> A financial or quantitative model where required by the scope</li>
          <li><span class="br-check">✓</span> Sourced claims and documented assumptions throughout</li>
          <li><span class="br-check">✓</span> Scope, fee basis, and delivery date confirmed in writing before work begins</li>
          <li><span class="br-check">✓</span> A working review call on delivery if included in scope</li>
        </ul>
      </div>
    </section>

    <!-- PROCESS -->
    <section class="br-section br-section--surface">
      <div class="br-container">
        <h2 class="br-h2">Process</h2>
        <div class="br-process">
          <div class="br-step">
            <span class="br-step-num">01</span>
            <div class="br-step-content">
              <h3 class="br-step-name">Brief</h3>
              <p>Submit the question, context, and timeline. No long form — a clear description of the decision you need to support.</p>
            </div>
          </div>
          <div class="br-step">
            <span class="br-step-num">02</span>
            <div class="br-step-content">
              <h3 class="br-step-name">Scoping</h3>
              <p>Autonomy Bridge returns a written scope covering output type, methodology, fee basis, and delivery timing. Confirmed before work begins.</p>
            </div>
          </div>
          <div class="br-step">
            <span class="br-step-num">03</span>
            <div class="br-step-content">
              <h3 class="br-step-name">Research</h3>
              <p>Primary and secondary source work, framework-driven analysis, and documented assumptions — built to withstand scrutiny.</p>
            </div>
          </div>
          <div class="br-step">
            <span class="br-step-num">04</span>
            <div class="br-step-content">
              <h3 class="br-step-name">Delivery</h3>
              <p>The completed output is delivered in document form, with a working review call if included in scope.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="br-cta-section">
      <div class="br-container br-cta-inner">
        <div>
          <h2 class="br-cta-heading">Start a Research Brief</h2>
          <p class="br-cta-sub">Begin with a 15-minute scoping call. Scope, fee basis, and delivery date are confirmed in writing before work begins.</p>
        </div>
        <div class="br-cta-actions">
          <a href="/contact" class="br-btn-primary">Book 15-min scoping call</a>
          <a href="/advisory" class="br-btn-outline">See Advisory</a>
        </div>
      </div>
    </section>

  </article>
</MainLayout>

<style>
  .br-page { font-family: var(--font-sans); }

  .br-container {
    max-width: 56rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  /* ── HEADER ── */
  .br-header {
    padding: 3.5rem 0 3rem;
    border-bottom: 1px solid var(--color-border-light);
  }

  .br-h1 {
    font-size: clamp(2rem, 1.6rem + 1.5vw, 2.75rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 0.5rem;
  }

  .br-tagline {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    margin: 0 0 1.5rem;
  }

  .br-intro {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0 0 1.5rem;
    text-align: justify;
  }

  .br-header-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .br-header-links a {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-accent);
    padding-bottom: 0.1rem;
  }

  /* ── SECTIONS ── */
  .br-section {
    padding: 3.5rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .br-section--surface { background: var(--color-bg-surface); }

  .br-h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    margin: 0 0 1.5rem;
  }

  /* ── RESEARCH TYPES ── */
  .br-types-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .br-type-card {
    padding: 1.25rem;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-default);
    border-top: 3px solid var(--color-border-accent);
    border-radius: 0.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .br-type-name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.3;
  }

  .br-type-card p {
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
    text-align: justify;
  }

  /* ── WHO COMMISSIONS ── */
  .br-who-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .br-who-item {
    padding: 1.125rem;
    background: #ffffff;
    border: 1px solid var(--color-border-default);
    border-radius: 0.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .br-who-label {
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-family: var(--font-mono);
  }

  .br-who-item p {
    font-size: 0.875rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .br-who-note {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0;
    font-style: italic;
  }

  /* ── DELIVERABLES ── */
  .br-deliverables {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .br-deliverables li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    padding: 0.875rem 1rem;
    background: var(--color-bg-surface);
    border-radius: 0.375rem;
    border: 1px solid var(--color-border-light);
  }

  .br-check {
    font-weight: 700;
    color: var(--color-border-accent);
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  /* ── PROCESS ── */
  .br-process {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .br-step {
    display: flex;
    gap: 1.25rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .br-step:last-child { border-bottom: none; }

  .br-step-num {
    font-family: var(--font-mono);
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-border-accent);
    flex-shrink: 0;
    width: 2.5rem;
    line-height: 1;
    padding-top: 0.125rem;
  }

  .br-step-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.375rem;
  }

  .br-step-content p {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
    text-align: justify;
  }

  /* ── CTA ── */
  .br-cta-section {
    background: var(--color-text-primary);
    padding: 3rem 0;
  }

  .br-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .br-cta-heading {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-cta-text);
    margin: 0 0 0.4rem;
  }

  .br-cta-sub {
    font-size: 0.9375rem;
    color: #94a3b8;
    margin: 0;
    max-width: 44ch;
    line-height: 1.6;
  }

  .br-cta-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .br-btn-primary {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    background: var(--color-cta-bg);
    border: 1.5px solid var(--color-cta-border);
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-cta-text);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .br-btn-primary:hover { background: #1e293b; border-color: #f59e0b; }

  .br-btn-outline {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    border: 1.5px solid #475569;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-cta-text);
    text-decoration: none;
    transition: border-color 0.15s;
  }

  .br-btn-outline:hover { border-color: var(--color-cta-border); }

  @media (max-width: 52rem) {
    .br-types-grid, .br-who-grid { grid-template-columns: 1fr; }
    .br-cta-inner { flex-direction: column; align-items: flex-start; }
  }
</style>
