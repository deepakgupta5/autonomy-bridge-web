---
import LegalPageTemplate from "../components/LegalPageTemplate.astro";
import { getEntryByCanonicalPath } from "../utils/contentCollections";

const canonicalPath = "/terms-of-use";
const entry = await getEntryByCanonicalPath("legal", canonicalPath);
const { Content } = await entry.render();
---

<LegalPageTemplate
  canonicalPath={canonicalPath}
  title={entry.data.title}
  summary={entry.data.summary}
  showHeader={false}
>
  <Content />
</LegalPageTemplate>
