---
import MainLayout from "../components/MainLayout.astro";

const canonicalPath = "/terms-of-use";
const title = "Terms of Use";
const summary = "Terms governing use of the Autonomy Bridge website and published content.";
---

<MainLayout canonicalPath={canonicalPath} title={title} summary={summary} seoTitle="Terms of Use | Autonomy Bridge">
  <article class="policy-page">
    <h1 class="type-h1">Terms of Use</h1>
    <p class="policy-meta">
      Last updated: March 15, 2026<br />
      Applies to users in Canada and the United States
    </p>

    <section>
      <h2 class="type-h2">Overview</h2>
      <p>By accessing this site, you agree to these terms.</p>
      <p>
        These terms apply to your use of the website and its content. They do not govern client
        engagements, which are covered by separate signed agreements where applicable.
      </p>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Intellectual Property</h2>
      <p>
        All content on this site, including frameworks, research methodologies, written analyses,
        market maps, and strategic models, is the proprietary work of Autonomy Bridge.
      </p>
      <p>
        The Autonomy Bridge name, logo, and associated marks may not be used without prior written
        permission.
      </p>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Permitted Use</h2>
      <p>You may:</p>
      <ul>
        <li>view content on this site</li>
        <li>reference content for personal or professional research</li>
        <li>share links to site pages</li>
      </ul>
      <p>No other use is permitted without written approval.</p>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Prohibited Use</h2>
      <p>The following are prohibited:</p>
      <ul>
        <li>copying, reproducing, or republishing site content without written permission</li>
        <li>reselling, sublicensing, or commercially exploiting site content</li>
        <li>scraping or systematically extracting content or data</li>
        <li>using site content to train AI or machine learning models</li>
        <li>misrepresenting Autonomy Bridge or attributing false statements to the firm</li>
      </ul>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">No Warranties</h2>
      <p>This site and its content are provided as is.</p>
      <p>
        Autonomy Bridge makes no warranty, express or implied, regarding accuracy, completeness,
        availability, or fitness for a particular purpose. Analysis may become outdated as market
        conditions change.
      </p>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Limitation of Liability</h2>
      <p>
        To the maximum extent permitted by law, Autonomy Bridge is not liable for direct, indirect,
        incidental, or consequential damages arising from use of the site or reliance on its
        content.
      </p>
      <p>
        This includes business, investment, procurement, and deployment decisions made using
        information published here.
      </p>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Governing Law</h2>
      <p>
        These terms are governed by the laws of British Columbia, Canada, without regard to
        conflict of law principles.
      </p>
      <p>For users in the United States, applicable federal law may also apply.</p>
    </section>

    <section class="policy-section">
      <h2 class="type-h2">Changes to These Terms</h2>
      <p>These terms may be updated from time to time.</p>
      <p>
        Continued use of the site after changes are posted constitutes acceptance of the updated
        version.
      </p>
    </section>
  </article>
</MainLayout>

<style>
  .policy-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .policy-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0.75rem 0 2rem;
    line-height: 1.6;
  }

  .policy-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border-light);
  }

  .policy-page :global(h2) {
    margin-bottom: 1rem;
  }

  .policy-page p + p {
    margin-top: 1rem;
  }

  .policy-page ul {
    margin: 1rem 0;
    padding-left: 1.5rem;
  }

  .policy-page li + li {
    margin-top: 0.4rem;
  }

  .policy-page a {
    color: var(--color-link);
    text-underline-offset: 0.14rem;
  }
</style>
