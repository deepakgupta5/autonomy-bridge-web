---
import MainLayout from "../../components/MainLayout.astro";
import { getEntriesByCanonicalPrefix, getEntryByCanonicalPath } from "../../utils/contentCollections";
import { formatSlugLabel } from "../../utils/slugLabel";
import { buildCollectionPageSchema } from "../../utils/schema";

interface GlossaryTermView {
  slug: string;
  title: string;
  href: string;
  definition: string;
  relatedLinks: Array<{ href: string; label: string }>;
}

const canonicalPath = "/glossary";
const hubEntry = await getEntryByCanonicalPath("glossary", canonicalPath);
const termEntries = await getEntriesByCanonicalPrefix("glossary", `${canonicalPath}/`, {
  excludeCanonicalPaths: [canonicalPath],
});

const sortedTerms = [...termEntries].sort((left, right) =>
  String(left.data.title).localeCompare(String(right.data.title))
);

const termPathBySlug = new Map(
  sortedTerms.map((entry) => [String(entry.data.slug), String(entry.data.canonicalPath)])
);

function collectRelatedLinks(entry: (typeof sortedTerms)[number]): Array<{ href: string; label: string }> {
  const links: Array<{ href: string; label: string }> = [];
  const seen = new Set<string>();

  const pushLink = (href: string, label: string) => {
    if (!href || seen.has(href)) {
      return;
    }
    links.push({ href, label });
    seen.add(href);
  };

  for (const frameworkSlug of entry.data.frameworks) {
    pushLink(`/frameworks/${frameworkSlug}`, formatSlugLabel(frameworkSlug));
  }

  for (const glossarySlug of entry.data.relatedGlossary) {
    const href = termPathBySlug.get(glossarySlug) ?? `/glossary/${glossarySlug}`;
    pushLink(href, formatSlugLabel(glossarySlug));
  }

  for (const insightSlug of entry.data.relatedInsights) {
    pushLink(`/insights/${insightSlug}`, formatSlugLabel(insightSlug));
  }

  for (const useCaseSlug of entry.data.relatedUseCases) {
    pushLink(`/use-cases/${useCaseSlug}`, formatSlugLabel(useCaseSlug));
  }

  for (const caseStudySlug of entry.data.relatedCaseStudies) {
    pushLink(`/case-studies/${caseStudySlug}`, formatSlugLabel(caseStudySlug));
  }

  return links.slice(0, 8);
}

const terms: GlossaryTermView[] = sortedTerms.map((entry) => ({
  slug: String(entry.data.slug),
  title: String(entry.data.title),
  href: String(entry.data.canonicalPath),
  definition: String(entry.data.definition || entry.data.description),
  relatedLinks: collectRelatedLinks(entry),
}));

const groups = new Map<string, GlossaryTermView[]>();
for (const term of terms) {
  const firstChar = term.title.trim().charAt(0).toUpperCase();
  const groupKey = /[A-Z]/.test(firstChar) ? firstChar : "#";
  const existing = groups.get(groupKey) ?? [];
  existing.push(term);
  groups.set(groupKey, existing);
}

const letters = [...groups.keys()].sort();
const metaLine = "Precise analytical definitions for warehouse automation, robotics deployment, and operating economics.";
const intro = String(hubEntry.data.description);
const summary = String(hubEntry.data.summary);
const schema = [
  buildCollectionPageSchema({
    name: "Glossary",
    description: summary,
    canonicalPath,
  }),
];
---

<MainLayout
  canonicalPath={canonicalPath}
  title="Glossary"
  summary={summary}
  seoTitle={String(hubEntry.data.seoTitle)}
  seoDescription={String(hubEntry.data.seoDescription)}
  schema={schema}
  showBreadcrumbs={false}
  showLocalSubnav={false}
>
  <div class="gl-wrap">

    <!-- Hero -->
    <header class="gl-hero">
      <h1 class="gl-h1">Glossary</h1>
      <p class="gl-tagline">Robotics Deployment Economics</p>
      <p class="gl-meta-line">{metaLine}</p>
      <p class="gl-intro">{intro}</p>
      <div class="gl-pills">
        <a href="/frameworks" class="gl-pill">Frameworks &rarr;</a>
        <a href="/insights" class="gl-pill">Insights &rarr;</a>
        <a href="/use-cases" class="gl-pill">Use Cases &rarr;</a>
      </div>
    </header>

    <!-- Alphabet index -->
    {
      letters.length > 1 && (
        <nav aria-label="Glossary index navigation" class="gl-alpha-nav">
          {letters.map((letter) => (
            <a href={`#glossary-letter-${letter}`} class="gl-alpha-letter">{letter}</a>
          ))}
        </nav>
      )
    }

    <!-- Terms -->
    <div class="gl-terms">
      {
        letters.map((letter) => {
          const groupTerms = groups.get(letter) ?? [];
          return (
            <section id={`glossary-letter-${letter}`} class="gl-group" aria-label={`Terms beginning with ${letter}`}>
              <h2 class="gl-group-letter">{letter}</h2>
              <div class="gl-group-terms">
                {groupTerms.map((term) => (
                  <article class="gl-term-card">
                    <h3 class="gl-term-name">
                      <a href={term.href}>{term.title}</a>
                    </h3>
                    <p class="gl-term-def">{term.definition}</p>
                    {
                      term.relatedLinks.length > 0 && (
                        <p class="gl-term-related">
                          Related:{" "}
                          {term.relatedLinks.map((link, index) => (
                            <>
                              {index > 0 && <span class="gl-sep"> · </span>}
                              <a href={link.href} class="gl-related-link">{link.label}</a>
                            </>
                          ))}
                        </p>
                      )
                    }
                  </article>
                ))}
              </div>
            </section>
          );
        })
      }
    </div>

  </div>
</MainLayout>

<style>
.gl-wrap {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 1.5rem 4rem;
}

/* Hero */
.gl-hero {
  padding: 3rem 0 2.5rem;
  border-bottom: 1px solid var(--color-border-light);
  margin-bottom: 2rem;
}
.gl-h1 {
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-text-primary);
  line-height: 1.1;
  margin-bottom: 0.4rem;
}
.gl-tagline {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--color-text-muted);
  letter-spacing: 0.06em;
  margin-bottom: 0.75rem;
}
.gl-meta-line {
  font-size: 0.9375rem;
  line-height: 1.75;
  color: var(--color-text-secondary);
  max-width: 62ch;
  margin-bottom: 0.875rem;
}
.gl-intro {
  max-width: 68ch;
  font-size: 1rem;
  line-height: 1.85;
  color: var(--color-text-secondary);
  margin-bottom: 1.5rem;
}
.gl-pills {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.gl-pill {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--color-text-primary);
  border: 1px solid var(--color-border-default);
  border-radius: 999px;
  padding: 0.25rem 0.75rem;
  text-decoration: none;
  transition: border-color 0.15s, background 0.15s;
}
.gl-pill:hover {
  border-color: var(--color-border-accent);
  background: var(--color-bg-accent);
}

/* Alphabet nav */
.gl-alpha-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
  margin-bottom: 2.5rem;
}
.gl-alpha-letter {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--color-text-primary);
  border: 1px solid var(--color-border-default);
  border-radius: 4px;
  text-decoration: none;
  transition: border-color 0.15s, background 0.15s, color 0.15s;
}
.gl-alpha-letter:hover {
  border-color: var(--color-border-accent);
  background: var(--color-bg-accent);
  color: var(--color-text-accent);
}

/* Letter groups */
.gl-terms {
  display: flex;
  flex-direction: column;
  gap: 3rem;
}
.gl-group-letter {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--color-border-accent);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--color-border-light);
  margin-bottom: 1.25rem;
}
.gl-group-terms {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

/* Term cards */
.gl-term-card {
  border: 1px solid var(--color-border-light);
  border-top: 3px solid var(--color-border-accent);
  border-radius: 6px;
  padding: 1.25rem 1.5rem;
  background: var(--color-bg-page);
  transition: box-shadow 0.15s;
}
.gl-term-card:hover {
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.gl-term-name {
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 0.5rem;
}
.gl-term-name a {
  color: inherit;
  text-decoration: none;
}
.gl-term-name a:hover {
  color: var(--color-text-accent);
}
.gl-term-def {
  font-size: 0.9rem;
  line-height: 1.8;
  color: var(--color-text-secondary);
}
.gl-term-related {
  margin-top: 0.75rem;
  font-size: 0.8rem;
  color: var(--color-text-muted);
}
.gl-sep {
  color: var(--color-border-default);
}
.gl-related-link {
  color: var(--color-text-secondary);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: var(--color-border-accent);
}
.gl-related-link:hover {
  color: var(--color-text-primary);
}
</style>
