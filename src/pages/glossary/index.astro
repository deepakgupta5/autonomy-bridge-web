---
import Layout from "../../components/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const terms = await getCollection("glossary");
const sorted = terms.sort((a, b) => a.data.title.localeCompare(b.data.title));

// Group alphabetically
const grouped: Record<string, typeof sorted> = {};
for (const term of sorted) {
  const letter = term.data.title[0].toUpperCase();
  if (!grouped[letter]) grouped[letter] = [];
  grouped[letter].push(term);
}
const letters = Object.keys(grouped).sort();
---

<Layout
  title="Glossary — Autonomy Bridge"
  description="Definitions of key terms in warehouse robotics and automation economics — AMR, RaaS, fleet utilization, utilization threshold, WMS integration, and more."
  canonicalPath="/glossary"
>
  <Header />

  <main class="container site-main">
    <h1>Glossary</h1>
    <p class="subhead reading-column">
      Definitions for key terms in warehouse automation, robotics deployment,
      and operational economics.
    </p>

    <nav class="breadcrumb glossary-alpha-nav" aria-label="Alphabetical navigation">
      {letters.map((letter, i) => (
        <>
          <a href={`#${letter}`}>{letter}</a>
          {i < letters.length - 1 && <span class="breadcrumb__separator" aria-hidden="true">·</span>}
        </>
      ))}
    </nav>

    {letters.map((letter) => (
      <section class="glossary-section reading-column" id={letter}>
        <h2>{letter}</h2>
        <dl class="glossary-list">
          {grouped[letter].map((term) => (
            <>
              <dt class="glossary-list__term">
                <a href={`/glossary/${term.slug}`}>
                  {term.data.title}{term.data.abbreviation ? ` (${term.data.abbreviation})` : ''}
                </a>
              </dt>
              <dd class="glossary-list__definition">{term.data.definition}</dd>
            </>
          ))}
        </dl>
      </section>
    ))}
  </main>

  <Footer />
</Layout>
