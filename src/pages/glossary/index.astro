---
import HubPageTemplate from "../../components/HubPageTemplate.astro";
import type { HubPageContent } from "../../data/hubContent";
import { glossaryTermSlugs } from "../../data/ia";
import {
  getEntriesByCanonicalPrefix,
  getEntryByCanonicalPath,
} from "../../utils/contentCollections";

const hubCanonicalPath = "/glossary";
const hubEntry = await getEntryByCanonicalPath("glossary", hubCanonicalPath);
const termEntries = await getEntriesByCanonicalPrefix("glossary", `${hubCanonicalPath}/`, {
  includeExact: false,
});

const termBySlug = new Map(termEntries.map((entry) => [entry.data.slug, entry]));
const items: HubPageContent["items"] = glossaryTermSlugs.flatMap((slug) => {
  const entry = termBySlug.get(slug);
  if (!entry) {
    return [];
  }

  return [
    {
      title: entry.data.title,
      href: entry.data.canonicalPath,
      description: entry.data.description,
      metadata: [`Updated: ${String(entry.data.dateModified)}`],
      taxonomy: entry.data.topics.length > 0 ? entry.data.topics : ["glossary"],
    },
  ];
});

const content: HubPageContent = {
  title: hubEntry.data.title,
  summary: hubEntry.data.summary,
  intro: hubEntry.data.description,
  emptyState: "No glossary terms are available yet.",
  items,
};

const { Content } = await hubEntry.render();
---

<HubPageTemplate canonicalPath={hubCanonicalPath} content={content}>
  <Content />
</HubPageTemplate>
