---
import GlossaryTermTemplate from "../../components/GlossaryTermTemplate.astro";
import { glossaryTermSlugs } from "../../data/ia";
import { getEntryByCanonicalPath } from "../../utils/contentCollections";

export function getStaticPaths() {
  return glossaryTermSlugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const canonicalPath = `/glossary/${slug}`;
const entry = await getEntryByCanonicalPath("glossary", canonicalPath);
const { Content } = await entry.render();
---

<GlossaryTermTemplate
  canonicalPath={canonicalPath}
  term={entry.data.title}
  slug={slug}
  definition={entry.data.description}
  summary={entry.data.summary}
>
  <Content />
</GlossaryTermTemplate>
