---
import Layout from "../../components/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { insights } from "../../data/insights";

export function getStaticPaths() {
  return insights.map((insight) => ({
    params: { slug: insight.slug },
    props: { insight },
  }));
}

const { insight } = Astro.props;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: insight.title,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": `https://www.autonomybridge.com/insights/${insight.slug}`,
  },
  author: {
    "@type": "Organization",
    name: "Autonomy Bridge",
    url: "https://www.autonomybridge.com/",
  },
  publisher: {
    "@type": "Organization",
    name: "Autonomy Bridge",
    url: "https://www.autonomybridge.com/",
  },
  description: insight.description,
};
---

<Layout
  title={`${insight.title} — Insights — Autonomy Bridge`}
  description={insight.description}
  schemaType="Article"
  schemaName={insight.title}
  canonicalPath={`/insights/${insight.slug}`}
  includePageSchema={false}
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>

  <Header />

  <main class="container site-main">
    <p class="insight-label">Insight</p>
    <h1>{insight.title}</h1>
    <p class="subhead reading-column">{insight.description}</p>

    <section class="section reading-column">
      <h2>Key Takeaways</h2>
      <ul>
        {insight.keyPoints.map((point) => <li>{point}</li>)}
      </ul>
    </section>

    <section class="section reading-column section-alt">
      <h2>Decision Boundary</h2>
      <div class="decision-block">
        <p class="decision-label">Output Signal</p>
        <p class="decision-value">{insight.decisionBoundary}</p>
      </div>
      <p class="insight-related">
        Related:
        <a href="/insights">All Insights</a> ·
        <a href={`/insights#${insight.id}`}>Source Section</a> ·
        <a href="/case-studies">Case Studies</a> ·
        <a href="/research">Research &amp; Advisory</a>
      </p>
    </section>
  </main>

  <Footer />
</Layout>
