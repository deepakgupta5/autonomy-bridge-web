---
import DetailPageTemplate from "../../components/DetailPageTemplate.astro";
import { insightSlugs } from "../../data/ia";
import { getEntryByCanonicalPath } from "../../utils/contentCollections";
import { extractFaqItemsFromMarkdown } from "../../utils/faq";

export function getStaticPaths() {
  return insightSlugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const canonicalPath = `/insights/${slug}`;
const entry = await getEntryByCanonicalPath("insights", canonicalPath);
const { Content } = await entry.render();
const faqItems = extractFaqItemsFromMarkdown(entry.body);
---

<DetailPageTemplate
  canonicalPath={canonicalPath}
  title={entry.data.title}
  summary={entry.data.summary}
  contentTypeLabel="Insight"
  schemaKind="insight"
  slug={slug}
  hubPath="/insights"
  hubLabel="Insights"
  datePublished={String(entry.data.datePublished)}
  dateModified={String(entry.data.dateModified)}
  authors={entry.data.authors}
  faqItems={faqItems}
>
  <Content />
</DetailPageTemplate>
