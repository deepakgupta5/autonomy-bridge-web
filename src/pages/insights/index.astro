---
import MainLayout from "../../components/MainLayout.astro";
import { buildCollectionPageSchema } from "../../utils/schema";

const canonicalPath = "/insights";
const title = "Insights";
const summary =
  "Structured research on warehouse automation, robotics deployment, industrial AI, and 3PL markets.";
const schema = [
  buildCollectionPageSchema({
    name: title,
    description: summary,
    canonicalPath,
  }),
];

const articles = [
  {
    href: "/insights/why-warehouse-automation-projects-fail",
    title: "Why Warehouse Automation Projects Fail",
    desc: "Most warehouse automation failures originate during project underwriting, not deployment. Fixed-capacity infrastructure requires stable demand that vendor ROI models systematically understate.",
    frameworkHref: "/frameworks/automation-failure-framework",
    frameworkLabel: "Automation Failure Framework",
  },
  {
    href: "/insights/why-robotics-pilots-fail-to-scale",
    title: "Why Robotics Pilots Fail to Scale",
    desc: "Robotics pilots test technical feasibility under controlled conditions that do not replicate full warehouse operations. Scaling requires proof of sustained utilization and economic viability.",
    frameworkHref: "/frameworks/pilot-to-scale-failure-framework",
    frameworkLabel: "Pilot-to-Scale Failure Framework",
  },
  {
    href: "/insights/why-mid-market-operators-struggle-to-evaluate-warehouse-robotics",
    title: "Why Mid-Market Operators Struggle to Evaluate Warehouse Robotics",
    desc: "Vendor ROI models assume stable demand. Mid-market 3PL operations rarely have it. A structural analysis of evaluation barriers specific to multi-client fulfillment environments.",
    frameworkHref: "/frameworks/warehouse-automation-decision-framework",
    frameworkLabel: "Warehouse Automation Decision Framework",
  },
  {
    href: "/insights/how-warehouse-robotics-economics-actually-works",
    title: "How Warehouse Robotics Economics Actually Works",
    desc: "Utilization, not robot speed, governs warehouse automation ROI. A capital allocation analysis covering utilization thresholds, bottleneck dynamics, and conditions for durable returns.",
    frameworkHref: "/frameworks/robotics-roi-model",
    frameworkLabel: "Robotics ROI Model",
  },
  {
    href: "/insights/how-warehouse-workflows-determine-automation-success",
    title: "How Warehouse Workflows Determine Automation Success",
    desc: "Warehouse throughput equals the capacity of the slowest linked process. Automation that improves one node without addressing downstream constraints creates congestion, not productivity.",
    frameworkHref: "/frameworks/workflow-architecture-framework",
    frameworkLabel: "Workflow Architecture Framework",
  },
  {
    href: "/insights/how-warehouse-operators-evaluate-robotics-vendors",
    title: "How Warehouse Operators Evaluate Robotics Vendors",
    desc: "The four-stage vendor evaluation process used by mid-size 3PL operators — from shortlist formation through cross-functional ROI approval — with emphasis on the utilization threshold.",
    frameworkHref: "/frameworks/vendor-evaluation-framework",
    frameworkLabel: "Vendor Evaluation Framework",
  },
  {
    href: "/insights/how-retail-distribution-center-automation-economics-actually-work",
    title: "How Retail Distribution Center Automation Economics Actually Work",
    desc: "Retail DC automation economics are governed by peak demand, not average utilization. A system that delivers strong ROI during a ten-week peak season may generate negative returns across the remaining forty-two weeks.",
    frameworkHref: "/frameworks/robotics-roi-model",
    frameworkLabel: "Robotics ROI Model",
  },
  {
    href: "/insights/why-cold-storage-automation-economics-are-structurally-different",
    title: "Why Cold Storage Automation Economics Are Structurally Different",
    desc: "Cold storage presents the strongest labor-cost ROI case in the warehouse sector and the most systematically miscalculated capital cost. Ambient benchmarks applied to cold environments produce fundamentally wrong investment cases.",
    frameworkHref: "/frameworks/robotics-roi-model",
    frameworkLabel: "Robotics ROI Model",
  },
  {
    href: "/insights/why-parcel-sortation-automation-breaks-at-low-volume",
    title: "Why Parcel Sortation Automation Breaks at Low Volume",
    desc: "Parcel sortation automation fails as a step function, not a gradual degradation. When volume drops below the sortation floor, per-parcel economics break regardless of peak utilization.",
    frameworkHref: "/frameworks/automation-failure-framework",
    frameworkLabel: "Automation Failure Framework",
  },
  {
    href: "/insights/why-general-merchandise-3pls-should-not-automate-too-early",
    title: "Why General Merchandise 3PLs Should Not Automate Too Early",
    desc: "Case and pallet operations have structurally lower labor intensity per order than ecommerce fulfillment. Many GM 3PL operators fail the economic pre-conditions for viable automation — competitive pressure is not a substitute for the analysis.",
    frameworkHref: "/frameworks/automation-failure-framework",
    frameworkLabel: "Automation Failure Framework",
  },
];
---

<MainLayout
  canonicalPath={canonicalPath}
  title={title}
  summary={summary}
  seoTitle="Insights | Autonomy Bridge"
  seoDescription={summary}
  schema={schema}
>
  <div class="insights-hub">

    <!-- ── Hero ──────────────────────────────── -->
    <header class="insights-hero">
      <h1 class="type-h1">Insights</h1>
      <p class="insights-tagline">{summary}</p>
      <p class="insights-who">For operators diagnosing deployment risk, investors stress-testing automation theses, and vendors mapping market entry.</p>
    </header>

    <!-- ── What this hub covers ──────────────── -->
    <section class="insights-section">
      <h2 class="type-h2 section-heading">What this hub covers</h2>
      <ul class="covers-list">
        <li>Warehouse automation economics and utilization risk</li>
        <li>Deployment failure patterns and root cause analysis</li>
        <li>Workflow architecture and throughput constraints</li>
        <li>Vendor evaluation and pilot-to-scale risk</li>
      </ul>
    </section>

    <!-- ── Featured analysis ─────────────────── -->
    <section class="insights-section">
      <h2 class="type-h2 section-heading">Featured analysis</h2>
      <div class="article-grid">
        {articles.map((a) => (
          <article class="article-card">
            <h3 class="article-title">
              <a href={a.href}>{a.title}</a>
            </h3>
            <p class="article-desc">{a.desc}</p>
            <p class="article-meta">
              Related framework:{" "}
              <a href={a.frameworkHref} class="meta-link">{a.frameworkLabel}</a>
            </p>
          </article>
        ))}
      </div>
    </section>

    <!-- ── Dark CTA ───────────────────────────── -->
    <section class="insights-cta">
      <p class="cta-text">Apply this research to your deployment decision.</p>
      <a href="/contact" class="cta-link">Book 15-min scoping call</a>
    </section>

    <!-- ── Related research infrastructure ───── -->
    <section class="insights-section insights-related">
      <h2 class="type-h2 section-heading">Related research infrastructure</h2>
      <p class="related-desc">
        Insights are linked to structured frameworks, applied use cases, case studies, and glossary
        terms so each article can be traced back to decision logic and implementation context.
      </p>
      <ul class="nav-pills">
        <li><a href="/frameworks">Frameworks</a></li>
        <li><a href="/use-cases">Use Cases</a></li>
        <li><a href="/case-studies">Case Studies</a></li>
        <li><a href="/methodology">Methodology</a></li>
        <li><a href="/glossary">Glossary</a></li>
      </ul>
    </section>

  </div>
</MainLayout>

<style>
  /* ── Container ──────────────────────────── */
  .insights-hub {
    max-width: 860px;
  }

  /* ── Hero ───────────────────────────────── */
  .insights-hero {
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border-light);
    margin-bottom: 3rem;
  }

  .insights-hero :global(h1) {
    margin: 0 0 0.85rem;
  }

  .insights-tagline {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 58ch;
  }
  .insights-who {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    max-width: 62ch;
    margin: 0.75rem 0 0;
  }

  /* ── Sections ───────────────────────────── */
  .insights-section {
    margin-bottom: 3.5rem;
  }

  .section-heading {
    margin: 0 0 1.5rem;
  }

  /* ── Covers list ────────────────────────── */
  .covers-list {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
    display: grid;
    gap: 0.6rem;
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: 1.7;
  }

  /* ── Article cards ──────────────────────── */
  .article-grid {
    display: grid;
    gap: 1.25rem;
  }

  .article-card {
    border: 1px solid var(--color-border-light);
    border-top: 3px solid var(--color-border-accent);
    border-radius: 6px;
    background: var(--color-bg-page);
    padding: 1.5rem;
    display: grid;
    gap: 0.65rem;
    transition: box-shadow 0.15s;
  }

  .article-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .article-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    line-height: 1.3;
    margin: 0;
  }

  .article-title a {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .article-title a:hover {
    color: var(--color-text-accent);
  }

  .article-desc {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .article-meta {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .meta-link {
    color: var(--color-text-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ── Dark CTA ───────────────────────────── */
  .insights-cta {
    background: var(--color-cta-bg);
    border-top: 3px solid var(--color-cta-border);
    border-radius: 6px;
    padding: 1.75rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 3.5rem;
  }

  .cta-text {
    color: var(--color-cta-text);
    font-size: var(--text-base);
    opacity: 0.85;
    margin: 0;
  }

  .cta-link {
    display: inline-block;
    border: 1px solid var(--color-cta-border);
    color: var(--color-cta-text);
    padding: 0.55rem 1.25rem;
    border-radius: 4px;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .cta-link:hover {
    background: rgba(217, 119, 6, 0.15);
  }

  /* ── Related infrastructure ─────────────── */
  .related-desc {
    margin: 0 0 1.25rem;
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--color-text-secondary);
    max-width: 58ch;
  }

  .nav-pills {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .nav-pills a {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    border: 1px solid var(--color-border-default);
    border-radius: 999px;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    background: var(--color-bg-page);
    transition: border-color 0.15s, color 0.15s;
  }

  .nav-pills a:hover {
    border-color: var(--color-border-accent);
    color: var(--color-text-accent);
  }
</style>
