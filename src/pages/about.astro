---
import Layout from "../components/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { renderMarkdown } from "../utils/markdownToHtml";
import aboutMarkdown from "../content/page-copy/about.md?raw";

const aboutHtml = await renderMarkdown(aboutMarkdown);
---

<Layout
  title="About — Autonomy Bridge"
  description="Autonomy Bridge provides warehouse automation economic analysis for operators, investors, and vendors making high-stakes robotics and AMR deployment decisions."
>
  <Header />

  <main class="container site-main">
    <article class="reading-column prose" set:html={aboutHtml} />
  </main>

  <Footer />
</Layout>
