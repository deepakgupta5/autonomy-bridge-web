---
import MainLayout from "../components/MainLayout.astro";
import { getEntryByCanonicalPath } from "../utils/contentCollections";
import { extractFaqItemsFromMarkdown } from "../utils/faq";
import { buildFaqPageSchema } from "../utils/schema";

const canonicalPath = "/about";
const entry = await getEntryByCanonicalPath("pages", canonicalPath);
const faqItems = extractFaqItemsFromMarkdown(entry.body);
const faqSchema = buildFaqPageSchema({ canonicalPath, items: faqItems });
const schema = faqSchema ? [faqSchema] : [];
---

<MainLayout
  canonicalPath={canonicalPath}
  title={entry.data.title}
  summary={entry.data.summary}
  seoTitle="About Autonomy Bridge | Autonomy Bridge"
  schema={schema}
>
  <article class="ab-page">

    <!-- HEADER -->
    <header class="ab-header">
      <div class="ab-container">
        <h1 class="ab-h1">About Autonomy Bridge</h1>
        <p class="ab-tagline">Principal-led boutique research firm for AI, robotics, and industrial automation markets.</p>
        <div class="ab-header-links">
          <a href="/frameworks">Frameworks →</a>
          <a href="/case-studies">Case Studies →</a>
          <a href="/methodology">Methodology →</a>
        </div>
      </div>
    </header>

    <!-- WHAT THE FIRM IS -->
    <section class="ab-section">
      <div class="ab-container">
        <h2 class="ab-h2">What Autonomy Bridge Is</h2>
        <p class="ab-body">Autonomy Bridge is a principal-led boutique research firm producing decision-grade research for vendors, investors, and operators in AI, robotics, and industrial automation markets. The firm helps decision-makers evaluate commercial viability, quantify opportunity, define ICP, and set pricing and go-to-market direction before committing capital or reputation.</p>
        <p class="ab-body" style="margin-top: 1rem;">Engagements produce decision briefs ,  explicit assumptions, structured models, and direct recommendations ,  not literature reviews, category surveys, or background documents. The output is built to resolve a specific decision, not to inform a general understanding of a market.</p>
        <p class="ab-body" style="margin-top: 1rem;">The firm operates as a structured knowledge platform, modeled on analyst research organizations rather than consulting practices. Its frameworks, research, and market intelligence are independent of any vendor, integrator, or implementation partner.</p>
      </div>
    </section>

    <!-- WHAT THE FIRM IS NOT -->
    <section class="ab-section ab-section--surface">
      <div class="ab-container">
        <h2 class="ab-h2">What Autonomy Bridge Is Not</h2>
        <ul class="ab-not-list">
          <li>Not a systems integrator ,  Autonomy Bridge does not implement, configure, or manage automation technology</li>
          <li>Not a vendor ,  holds no commercial relationship with robotics or AI suppliers, and accepts no fees, referral arrangements, or sponsored research</li>
          <li>Not a staffing firm, software reseller, or change management practice</li>
        </ul>
        <p class="ab-note">These distinctions are structural: they protect the integrity of the analysis.</p>
      </div>
    </section>

    <!-- RESEARCH MANDATE -->
    <section class="ab-section">
      <div class="ab-container">
        <h2 class="ab-h2">Research Mandate</h2>
        <p class="ab-body">The firm's analytical mission is to produce structured, evidence-based research on AI, robotics, and industrial automation markets ,  with depth across commercial viability assessment, vendor economics, deployment failure patterns, market entry analysis, ICP definition, and pricing strategy.</p>
        <p class="ab-body" style="margin-top: 1rem;">The research covers platform categories from intralogistics and service robotics to aerial systems, off-highway autonomy, and wearable robotics, and operator domains from warehousing and manufacturing to healthcare, agriculture, energy infrastructure, and commercial facilities.</p>
        <p class="ab-body" style="margin-top: 1rem;">Every framework, case study, and research engagement is built to answer the questions that vendors, investors, and operators carry into high-stakes decisions: Is this market real for this product? What does the addressable opportunity actually look like bottom-up? Which buyers are reachable and closeable? What will the market bear on price? Where do deployments fail and why?</p>
        <div class="ab-mandate-links">
          <a href="/frameworks" class="ab-text-link">Frameworks →</a>
          <a href="/methodology" class="ab-text-link">Methodology →</a>
        </div>
      </div>
    </section>

    <!-- FOUNDER -->
    <section class="ab-section ab-section--surface">
      <div class="ab-container">
        <h2 class="ab-h2">Founder</h2>
        <div class="ab-founder">
          <div class="ab-founder-photo">
            <img
              src="/founder/deepak-gupta.jpg"
              alt="Deepak Gupta ,  Founder and Principal Analyst, Autonomy Bridge"
              loading="lazy"
            />
          </div>
          <div class="ab-founder-bio">
            <h3 class="ab-founder-name">Deepak Gupta</h3>
            <p class="ab-founder-role">Founder · Principal Analyst</p>
            <p class="ab-founder-text">Deepak Gupta is the founder of Autonomy Bridge and serves as its principal analyst. He has held commercial and market development roles at eBay/Baazee, Ottonomy Robotics, and Industrybuying.com, with operating experience across North America, Europe, and Asia-Pacific spanning robotics go-to-market, B2B industrial procurement, and AI market entry.</p>
            <p class="ab-founder-text">His analytical work focuses on the gap between what vendors claim and what markets actually support ,  in commercial viability, deployment economics, and go-to-market sequencing.</p>
            <div class="ab-founder-links">
              <a href="https://www.linkedin.com/in/deepakgupta5" target="_blank" rel="noopener noreferrer">LinkedIn →</a>
              <a href="/contact">Contact</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHY THIS MATTERS -->
    <section class="ab-section">
      <div class="ab-container">
        <h2 class="ab-h2">Why This Matters</h2>
        <p class="ab-body">Vendors commit to markets, investors write checks, and operators sign contracts ,  often without access to independent analysis of whether the commercial assumptions hold. Vendor materials are not neutral. Market size figures are frequently top-down and unverifiable. Deployment economics are modeled on best-case utilization. Failure mode data is not publicly disclosed.</p>
        <p class="ab-body" style="margin-top: 1rem;">Macro analyst coverage from firms like Gartner, IDC, and McKinsey is built for enterprise strategy teams with long planning horizons. It does not serve the vendor deciding which segment to enter first, the investor stress-testing a deployment thesis, or the operator evaluating whether a specific platform makes economic sense for their environment.</p>
        <p class="ab-body ab-body--emphasis" style="margin-top: 1rem;">Autonomy Bridge produces structured, independent analysis at the decision unit that actually bears the risk ,  before the capital is committed or the reputation is staked.</p>
      </div>
    </section>

    <!-- RESEARCH MODEL -->
    <section class="ab-section ab-section--surface">
      <div class="ab-container">
        <h2 class="ab-h2">The Research Model</h2>
        <p class="ab-body">Autonomy Bridge is built as an analyst platform ,  not a consulting brochure ,  modeled on the knowledge architecture of organizations like CB Insights and Verdantix, where structured frameworks, defined methodologies, and permanent research assets do the work that marketing copy cannot.</p>
        <div class="ab-platform-grid">
          <a href="/frameworks" class="ab-platform-link">Frameworks</a>
          <a href="/glossary" class="ab-platform-link">Glossary</a>
          <a href="/use-cases" class="ab-platform-link">Use Cases</a>
          <a href="/case-studies" class="ab-platform-link">Case Studies</a>
          <a href="/insights" class="ab-platform-link">Insights</a>
          <a href="/market-overview" class="ab-platform-link">Market Overview</a>
        </div>
      </div>
    </section>

    <!-- WORK WITH US -->
    <section class="ab-cta-section">
      <div class="ab-container ab-cta-inner">
        <div>
          <h2 class="ab-cta-heading">Work With Autonomy Bridge</h2>
          <ul class="ab-cta-services">
            <li><strong>Advisory</strong> ,  Ongoing analytical support for vendors, investors, and operators navigating evolving decisions in AI, robotics, and industrial automation markets.</li>
            <li><strong>Bespoke Research</strong> ,  A single defined research engagement scoped to a specific question, with a fixed deliverable and a fixed endpoint.</li>
          </ul>
        </div>
        <div class="ab-cta-actions">
          <a href="/advisory" class="ab-btn-primary">Engage Advisory →</a>
          <a href="/bespoke-research" class="ab-btn-outline">Commission Bespoke Research →</a>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    {faqItems.length > 0 && (
      <section class="ab-section">
        <div class="ab-container ab-faq-container">
          <h2 class="ab-h2">Frequently Asked Questions</h2>
          <div class="ab-faq-list">
            {faqItems.map((item) => (
              <details class="ab-faq-item">
                <summary class="ab-faq-q">{item.question}</summary>
                <p class="ab-faq-a">{item.answer}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

  </article>
</MainLayout>

<style>
  .ab-page { font-family: var(--font-sans); }

  .ab-container {
    max-width: 56rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  /* ── HEADER ── */
  .ab-header {
    padding: 3.5rem 0 3rem;
    border-bottom: 1px solid var(--color-border-light);
  }

  .ab-h1 {
    font-size: clamp(2rem, 1.6rem + 1.5vw, 2.75rem);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0 0 0.5rem;
  }

  .ab-tagline {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
    margin: 0 0 1.5rem;
  }

  .ab-header-links {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .ab-header-links a {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-accent);
    padding-bottom: 0.1rem;
  }

  .ab-header-links a:hover { color: var(--color-text-muted); }

  /* ── SECTIONS ── */
  .ab-section {
    padding: 3.5rem 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .ab-section--surface { background: var(--color-bg-surface); }

  .ab-h2 {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
    margin: 0 0 1.25rem;
  }

  .ab-body {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .ab-body--emphasis {
    color: var(--color-text-primary);
    font-weight: 500;
  }

  .ab-note {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 1rem 0 0;
  }

  /* ── NOT LIST ── */
  .ab-not-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .ab-not-list li {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
    padding: 1rem 1.125rem;
    background: #ffffff;
    border: 1px solid var(--color-border-default);
    border-radius: 0.375rem;
  }

  /* ── MANDATE LINKS ── */
  .ab-mandate-links {
    display: flex;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .ab-text-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-accent);
    padding-bottom: 0.1rem;
  }

  .ab-text-link:hover { color: var(--color-text-muted); }

  /* ── FOUNDER ── */
  .ab-founder {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.75rem;
    align-items: start;
  }

  .ab-founder-photo {
    width: 5rem;
    height: 5rem;
    border-radius: 0.375rem;
    overflow: hidden;
    border: 1px solid var(--color-border-default);
    flex-shrink: 0;
  }

  .ab-founder-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ab-founder-name {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.2rem;
  }

  .ab-founder-role {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    margin: 0 0 1rem;
  }

  .ab-founder-text {
    font-size: 0.9375rem;
    line-height: 1.75;
    color: var(--color-text-secondary);
    margin: 0 0 0.75rem;
  }

  .ab-founder-links {
    display: flex;
    gap: 1.25rem;
    margin-top: 0.5rem;
  }

  .ab-founder-links a {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border-accent);
    padding-bottom: 0.1rem;
  }

  /* ── PLATFORM GRID ── */
  .ab-platform-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .ab-platform-link {
    display: block;
    padding: 0.875rem 1rem;
    background: #ffffff;
    border: 1px solid var(--color-border-default);
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-primary);
    text-decoration: none;
    text-align: center;
    transition: border-color 0.15s, background 0.15s;
  }

  .ab-platform-link:hover {
    border-color: var(--color-border-accent);
    background: var(--color-bg-surface);
  }

  /* ── CTA ── */
  .ab-cta-section {
    background: var(--color-text-primary);
    padding: 3rem 0;
  }

  .ab-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .ab-cta-heading {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-cta-text);
    margin: 0 0 0.75rem;
  }

  .ab-cta-services {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .ab-cta-services li {
    font-size: 0.875rem;
    color: #94a3b8;
    line-height: 1.55;
  }

  .ab-cta-services li strong {
    color: var(--color-cta-text);
    font-weight: 600;
  }

  .ab-cta-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .ab-btn-primary {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    background: var(--color-cta-bg);
    border: 1.5px solid var(--color-cta-border);
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-cta-text);
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
    white-space: nowrap;
  }

  .ab-btn-primary:hover { background: #1e293b; border-color: #f59e0b; }

  .ab-btn-outline {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    border: 1.5px solid #475569;
    border-radius: 0.375rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-cta-text);
    text-decoration: none;
    transition: border-color 0.15s;
    white-space: nowrap;
  }

  .ab-btn-outline:hover { border-color: var(--color-cta-border); }

  /* ── FAQ ── */
  .ab-faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ab-faq-item {
    border: 1px solid var(--color-border-default);
    border-radius: 0.375rem;
    overflow: hidden;
  }

  .ab-faq-q {
    display: block;
    padding: 0.875rem 1rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-primary);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .ab-faq-q::-webkit-details-marker { display: none; }

  .ab-faq-q::after {
    content: "+";
    float: right;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  details[open] .ab-faq-q::after { content: "−"; }

  .ab-faq-a {
    padding: 0 1rem 1rem;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 48rem) {
    .ab-founder { grid-template-columns: 1fr; }
    .ab-platform-grid { grid-template-columns: 1fr 1fr; }
    .ab-cta-inner { flex-direction: column; align-items: flex-start; }
    .ab-cta-actions { flex-direction: row; flex-wrap: wrap; }
  }
</style>
