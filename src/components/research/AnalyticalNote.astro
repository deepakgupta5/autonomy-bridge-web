---
import { renderInlineMarkdown } from "../../utils/inlineMarkdown";

interface Props {
  text: string;
}

const { text } = Astro.props;
---

<aside class="analytical-note mt-6 border-l border-neutral-300 pl-5 text-neutral-800">
  <p class="text-base md:text-[17px] leading-8" set:html={renderInlineMarkdown(text)} />
</aside>

<style>
  p {
    margin: 0;
  }
</style>
