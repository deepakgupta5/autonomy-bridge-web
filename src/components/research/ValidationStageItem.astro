---
import { renderInlineMarkdown } from "../../utils/inlineMarkdown";
import type { StageLine } from "../../utils/researchDocument";

interface Props {
  item: StageLine;
}

const { item } = Astro.props;
---

<li class="validation-stage border border-neutral-200 px-5 py-4">
  <div class="stage-number text-sm font-semibold tracking-wide text-neutral-500 uppercase">
    Stage {item.stageNumber}
  </div>
  <h3 class="stage-title text-lg md:text-xl font-semibold leading-snug mt-2 mb-2">{item.heading}</h3>
  <div class="stage-body text-base md:text-[17px] leading-8 text-neutral-800">
    <p set:html={renderInlineMarkdown(item.body)} />
  </div>
</li>

<style>
  p {
    margin: 0;
  }
</style>
