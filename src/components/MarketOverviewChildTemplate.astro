---
import MainLayout from "./MainLayout.astro";

interface Props {
  canonicalPath: string;
  title: string;
  summary?: string;
}

const { canonicalPath, title, summary = "Market overview analysis." } = Astro.props;

const subpages = [
  { href: "/market-overview/industry-landscape", label: "Industry Landscape" },
  { href: "/market-overview/technology-stack", label: "Technology Stack" },
  { href: "/market-overview/market-drivers", label: "Market Drivers" },
  { href: "/market-overview/market-segments", label: "Market Segments" },
  { href: "/market-overview/key-players", label: "Key Players" },
];
---

<MainLayout title={title} summary={summary} canonicalPath={canonicalPath} showBreadcrumbs={false} showLocalSubnav={false}>
  <div class="mc-wrap">

    <!-- Header -->
    <header class="mc-header">
      <p class="mc-breadcrumb">
        Home / <a href="/market-overview">Market Overview</a> / {title}
      </p>
      <h1 class="mc-h1">{title}</h1>
      <p class="mc-tagline">Warehouse Automation Market Overview · Autonomy Bridge</p>
      {summary && summary !== "Market overview analysis." && <p class="mc-summary">{summary}</p>}
    </header>

    <!-- Sub-navigation -->
    <nav class="mc-subnav" aria-label="Market overview sections">
      {subpages.map((page) => (
        <a
          href={page.href}
          class={`mc-subnav-link${page.href === canonicalPath ? " mc-subnav-link--active" : ""}`}
        >
          {page.label}
        </a>
      ))}
    </nav>

    <!-- Body content -->
    <article class="mc-body prose-surface">
      <slot />
    </article>

    <!-- CTA -->
    <section class="mc-cta">
      <h2 class="mc-cta-h">Apply this context to a specific decision</h2>
      <p class="mc-cta-sub">Advisory engagements and bespoke research go beyond market context into specific deployment economics, vendor assessment, and operational risk.</p>
      <div class="mc-cta-btns">
        <a href="/advisory" class="mc-cta-btn mc-cta-btn--primary">Advisory &rarr;</a>
        <a href="/frameworks" class="mc-cta-btn mc-cta-btn--outline">Frameworks &rarr;</a>
      </div>
    </section>

  </div>
</MainLayout>

<style>
.mc-wrap {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 1.5rem 4rem;
}

/* Header */
.mc-header {
  padding: 3rem 0 2rem;
  border-bottom: 1px solid var(--color-border-light);
  margin-bottom: 1.5rem;
}
.mc-breadcrumb {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--color-text-subtle);
  letter-spacing: 0.04em;
  margin-bottom: 1.25rem;
}
.mc-breadcrumb a {
  color: var(--color-text-subtle);
  text-decoration: underline;
  text-underline-offset: 3px;
}
.mc-h1 {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-text-primary);
  line-height: 1.15;
  margin-bottom: 0.5rem;
}
.mc-tagline {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--color-text-muted);
  letter-spacing: 0.06em;
}
.mc-summary {
  font-size: 1rem;
  line-height: 1.75;
  color: var(--color-text-secondary);
  max-width: 62ch;
  margin-top: 0.875rem;
}

/* Sub-nav */
.mc-subnav {
  display: flex;
  flex-wrap: wrap;
  gap: 0.375rem;
  margin-bottom: 2.5rem;
}
.mc-subnav-link {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--color-text-muted);
  border: 1px solid var(--color-border-light);
  border-radius: 4px;
  padding: 0.25rem 0.625rem;
  text-decoration: none;
  transition: border-color 0.15s, color 0.15s, background 0.15s;
}
.mc-subnav-link:hover {
  border-color: var(--color-border-accent);
  color: var(--color-text-primary);
}
.mc-subnav-link--active {
  border-color: var(--color-border-accent);
  color: var(--color-text-accent);
  background: var(--color-bg-accent);
  font-weight: 600;
}

/* Body */
.mc-body :global(p) {
  line-height: 1.9;
}
.mc-body :global(p + p) {
  margin-top: 1.25rem;
}
/* Hide the "**Page URL:**" metadata line embedded in the markdown */
.mc-body :global(p:first-child) {
  display: none;
}
/* Hide "**Related Frameworks:**" empty line */
.mc-body :global(p:nth-child(2)) {
  display: none;
}
.mc-body :global(strong) {
  color: var(--color-text-primary);
}
.mc-body :global(a) {
  color: var(--color-text-primary);
  text-decoration-color: var(--color-border-accent);
}
.mc-body :global(a:hover) {
  color: var(--color-text-accent);
}
.mc-body :global(hr) {
  border: none;
  border-top: 1px solid var(--color-border-light);
  margin: 2rem 0;
}

/* CTA */
.mc-cta {
  margin-top: 3.5rem;
  padding: 2rem 1.5rem;
  background: var(--color-cta-bg);
  border-radius: 8px;
}
.mc-cta-h {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-cta-text);
  letter-spacing: -0.015em;
  margin-bottom: 0.5rem;
}
.mc-cta-sub {
  font-size: 0.875rem;
  line-height: 1.7;
  color: #94a3b8;
  max-width: 54ch;
  margin-bottom: 1.5rem;
}
.mc-cta-btns { display: flex; flex-wrap: wrap; gap: 0.625rem; }
.mc-cta-btn {
  display: inline-block;
  font-size: 0.8125rem;
  font-weight: 600;
  padding: 0.5rem 1rem;
  border-radius: 5px;
  text-decoration: none;
  transition: background 0.15s, border-color 0.15s;
}
.mc-cta-btn--primary {
  background: transparent;
  color: var(--color-cta-text);
  border: 1.5px solid var(--color-cta-border);
}
.mc-cta-btn--primary:hover {
  background: var(--color-cta-border);
  color: var(--color-cta-bg);
}
.mc-cta-btn--outline {
  background: transparent;
  color: #94a3b8;
  border: 1.5px solid #334155;
}
.mc-cta-btn--outline:hover {
  border-color: #94a3b8;
  color: var(--color-cta-text);
}
</style>
