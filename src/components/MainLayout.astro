---
import Breadcrumbs from "./Breadcrumbs.astro";
import Footer from "./Footer.astro";
import Header from "./Header.astro";
import LocalSubnav from "./LocalSubnav.astro";
import "../styles/global.css";
import { buildBreadcrumbs, getLocalSubnav, normalizePathname } from "../utils/navigation";
import { resolvePageMetadata } from "../utils/metadata";
import { buildDefaultLayoutSchemas, type SchemaNode } from "../utils/schema";

interface Props {
  title: string;
  summary?: string;
  canonicalPath?: string;
  canonicalHref?: string;
  seoTitle?: string;
  seoDescription?: string;
  keywords?: string[];
  robots?: string;
  ogType?: string;
  ogTitle?: string;
  ogDescription?: string;
  twitterCard?: string;
  showBreadcrumbs?: boolean;
  showLocalSubnav?: boolean;
  schema?: SchemaNode[];
}

const {
  title,
  summary = "",
  canonicalPath,
  canonicalHref,
  seoTitle,
  seoDescription,
  keywords,
  robots,
  ogType,
  ogTitle,
  ogDescription,
  twitterCard,
  showBreadcrumbs = true,
  showLocalSubnav = true,
  schema = [],
} = Astro.props;

const currentPath = normalizePathname(canonicalPath ?? Astro.url.pathname);
const metadata = resolvePageMetadata({
  title,
  summary,
  canonicalPath: currentPath,
  seoTitle,
  seoDescription,
  keywords,
  robots,
  ogType,
});
const breadcrumbs = showBreadcrumbs ? buildBreadcrumbs(currentPath) : [];
const localSubnav = showLocalSubnav ? getLocalSubnav(currentPath) : null;
const breadcrumbSchemaItems = breadcrumbs.map((item, index) => ({
  label: item.label,
  path: item.href ?? (index === breadcrumbs.length - 1 ? currentPath : "/"),
}));
const defaultSchemas = buildDefaultLayoutSchemas({
  breadcrumbItems: breadcrumbSchemaItems,
});
const schemaEntries = [...defaultSchemas, ...schema];
const resolvedOgTitle = ogTitle ?? metadata.ogTitle;
const resolvedOgDescription = ogDescription ?? metadata.description;
const resolvedTwitterCard = twitterCard ?? "summary";
const resolvedOgUrl = canonicalHref ?? metadata.absoluteCanonicalUrl;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@600;700&family=Inter:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{metadata.titleTag}</title>
    {metadata.description && <meta name="description" content={metadata.description} />}
    {metadata.keywordsContent && <meta name="keywords" content={metadata.keywordsContent} />}
    <meta name="robots" content={metadata.robots} />
    <link rel="canonical" href={canonicalHref ?? metadata.canonicalPath} />
    <meta property="og:site_name" content="Autonomy Bridge" />
    <meta property="og:type" content={ogType ?? metadata.ogType} />
    <meta property="og:title" content={resolvedOgTitle} />
    {resolvedOgDescription && <meta property="og:description" content={resolvedOgDescription} />}
    <meta property="og:url" content={resolvedOgUrl} />
    <meta name="twitter:card" content={resolvedTwitterCard} />
    <meta name="twitter:title" content={resolvedOgTitle} />
    {resolvedOgDescription && <meta name="twitter:description" content={resolvedOgDescription} />}
    {
      schemaEntries.map((entry) => (
        <script type="application/ld+json" set:html={JSON.stringify(entry)} />
      ))
    }
  </head>
  <body>
    <Header currentPath={currentPath} />
    <main class="page-main">
      <div class="page-content">
        {breadcrumbs.length > 1 && <Breadcrumbs items={breadcrumbs} />}
        {localSubnav && (
          <LocalSubnav
            heading={localSubnav.heading}
            links={localSubnav.links}
            currentPath={currentPath}
          />
        )}
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-main {
    min-height: 60vh;
  }

  .page-content {
    max-width: 82rem;
    margin: 0 auto;
    padding: 3rem 2rem 5rem;
  }
</style>
