---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  width: number;
  height: number;
  loading?: "lazy" | "eager";
  id?: string;
}

const {
  src,
  alt,
  caption = "",
  width,
  height,
  loading = "lazy",
  id,
} = Astro.props;

const ratio = `${Math.max(width, 1)} / ${Math.max(height, 1)}`;
const figureId =
  id ??
  src
    .replace(/[^a-zA-Z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "")
    .toLowerCase();
const dialogId = `figure-dialog-${figureId}`;
---

<figure class="zoom-figure">
  <button
    type="button"
    class="zoom-trigger"
    data-dialog-target={dialogId}
    aria-controls={dialogId}
    aria-haspopup="dialog"
  >
    <span class="zoom-frame" style={`aspect-ratio: ${ratio};`}>
      <img src={src} alt={alt} width={width} height={height} loading={loading} decoding="async" />
    </span>
  </button>
  {caption && <figcaption class="type-caption">{caption}</figcaption>}

  <dialog id={dialogId} class="zoom-dialog">
    <button type="button" class="zoom-close type-caption" data-dialog-close={dialogId}>Close</button>
    <img src={src} alt={alt} width={width} height={height} loading="eager" decoding="async" />
    {caption && <p class="type-caption">{caption}</p>}
  </dialog>
</figure>

<script>
  const openButtons = document.querySelectorAll<HTMLButtonElement>("[data-dialog-target]");
  openButtons.forEach((button) => {
    if (button.dataset.bound === "true") {
      return;
    }

    button.dataset.bound = "true";
    button.addEventListener("click", () => {
      const targetId = button.getAttribute("data-dialog-target");
      if (!targetId) {
        return;
      }
      const dialog = document.getElementById(targetId);
      if (dialog instanceof HTMLDialogElement) {
        dialog.showModal();
      }
    });
  });

  const closeButtons = document.querySelectorAll<HTMLButtonElement>("[data-dialog-close]");
  closeButtons.forEach((button) => {
    if (button.dataset.bound === "true") {
      return;
    }

    button.dataset.bound = "true";
    button.addEventListener("click", () => {
      const targetId = button.getAttribute("data-dialog-close");
      if (!targetId) {
        return;
      }
      const dialog = document.getElementById(targetId);
      if (dialog instanceof HTMLDialogElement) {
        dialog.close();
      }
    });
  });
</script>

<style>
  .zoom-figure {
    margin: 1.5rem 0;
  }

  .zoom-trigger {
    border: 0;
    padding: 0;
    background: transparent;
    width: 100%;
    cursor: zoom-in;
    text-align: left;
  }

  .zoom-frame {
    display: block;
    width: 100%;
    max-width: 60rem;
    margin-inline: auto;
    border: 0.0625rem solid var(--color-border-default);
    border-radius: 0.5rem;
    background: var(--color-bg-page);
    overflow: hidden;
  }

  .zoom-frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .zoom-figure figcaption {
    margin-top: 0.5rem;
    color: var(--color-text-muted);
  }

  .zoom-dialog {
    border: 0;
    border-radius: 0.75rem;
    padding: 1rem;
    max-width: 92vw;
    width: 70rem;
    background: var(--color-bg-page);
  }

  .zoom-dialog::backdrop {
    background: rgb(15 23 42 / 0.7);
  }

  .zoom-close {
    border: 0.0625rem solid var(--color-border-default);
    background: var(--color-bg-page);
    border-radius: 999rem;
    padding: 0.3rem 0.8rem;
    cursor: pointer;
    margin-bottom: 0.75rem;
  }

  .zoom-dialog img {
    width: 100%;
    height: auto;
    border-radius: 0.375rem;
    border: 0.0625rem solid var(--color-border-light);
  }

  .zoom-dialog p {
    margin: 0.6rem 0 0;
    color: var(--color-text-secondary);
  }
</style>
