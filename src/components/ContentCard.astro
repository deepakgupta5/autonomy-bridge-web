---
import TaxonomyChips from "./TaxonomyChips.astro";
import type { HubCardItem } from "../data/hubContent";

interface Props {
  item: HubCardItem;
}

const { item } = Astro.props;
---

<article class="content-card">
  <h2 class="type-h4">
    <a href={item.href}>{item.title}</a>
  </h2>
  <p class="type-body">{item.description}</p>
  <ul class="card-metadata">
    {item.metadata.map((metaEntry) => <li class="type-meta">{metaEntry}</li>)}
  </ul>
  <TaxonomyChips chips={item.taxonomy} />
</article>

<style>
  .content-card {
    border: 1px solid var(--color-border-light);
    border-top: 3px solid var(--color-border-accent);
    border-radius: 6px;
    background: var(--color-bg-page);
    padding: 1.25rem;
    display: grid;
    gap: 0.7rem;
    transition: box-shadow 0.15s;
  }

  .content-card:hover {
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }

  .content-card h2 {
    margin: 0;
  }

  .content-card a {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .content-card a:hover {
    color: var(--color-text-accent);
  }

  .content-card p {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .card-metadata {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.3rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }
</style>
