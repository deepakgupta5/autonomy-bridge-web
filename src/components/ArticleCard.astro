---
import ContentClusterBadge from './ContentClusterBadge.astro';

const { title, description, slug, cluster, pubDate } = Astro.props;
const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---
<article class="article-card">
  <ContentClusterBadge cluster={cluster} />
  <h3 class="article-card__title">
    <a href={`/insights/${slug}`}>{title}</a>
  </h3>
  <p class="article-card__description">{description}</p>
  <p class="article-card__meta meta-text">{formattedDate}</p>
</article>
