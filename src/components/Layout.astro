---
import "../styles/global.css";

const siteUrl = "https://autonomybridge.com";
const {
  title,
  description,
  schemaType = "WebPage",
  schemaName,
  canonicalPath = Astro.url.pathname,
  includePageSchema = true,
} = Astro.props;

const normalizedPath = canonicalPath.startsWith("/") ? canonicalPath : `/${canonicalPath}`;
const canonicalUrl = new URL(normalizedPath, `${siteUrl}/`).toString();
const derivedSchemaName = schemaName ?? (title.includes(" — ") ? title.split(" — ")[0] : title);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Autonomy Bridge",
  url: `${siteUrl}/`,
  description:
    "AI and robotics market research, industrial automation GTM analysis, and enterprise AI commercialization research for high-stakes technology decisions.",
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Autonomy Bridge",
  url: `${siteUrl}/`,
};

const pageSchema = {
  "@context": "https://schema.org",
  "@type": schemaType,
  name: derivedSchemaName,
  url: canonicalUrl,
  description,
};

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Deepak Gupta",
  jobTitle: "Principal",
  worksFor: {
    "@type": "Organization",
    name: "Autonomy Bridge",
    url: siteUrl,
  },
  sameAs: ["https://www.linkedin.com/in/deepakgupta5"],
};
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href="/favicon.svg" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@500;600&family=Inter:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://autonomybridge.com/og-image.png" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
  {includePageSchema && <script type="application/ld+json" set:html={JSON.stringify(pageSchema)}></script>}
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>
  <slot name="head" />
</head>
<body>
  <slot />
  <!-- Netlify Forms registration — required for build bot detection with Astro -->
  <form name="contact" netlify netlify-honeypot="bot-field" hidden>
    <input type="text" name="name" />
    <input type="email" name="email" />
    <input type="text" name="company" />
    <input type="text" name="subject" />
    <textarea name="message"></textarea>
  </form>
</body>
</html>
