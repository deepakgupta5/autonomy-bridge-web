---
import "../styles/global.css";

const siteUrl = "https://www.autonomybridge.com";
const {
  title,
  description,
  schemaType = "WebPage",
  schemaName,
  canonicalPath = Astro.url.pathname,
  includePageSchema = true,
  articleData,
  faqData,
  breadcrumbs,
  serviceSchema,
  definedTermData,
} = Astro.props;

const normalizedPath = canonicalPath.startsWith("/") ? canonicalPath : `/${canonicalPath}`;
const canonicalUrl = new URL(normalizedPath, `${siteUrl}/`).toString();
const derivedSchemaName = schemaName ?? (title.includes(" — ") ? title.split(" — ")[0] : title);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Autonomy Bridge",
  url: `${siteUrl}/`,
  description:
    "AI and robotics market research, industrial automation GTM analysis, and enterprise AI commercialization research for high-stakes technology decisions.",
  founder: {
    "@type": "Person",
    name: "Deepak Gupta",
    sameAs: "https://www.linkedin.com/in/deepakgupta5",
  },
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Autonomy Bridge",
  url: `${siteUrl}/`,
};

const pageSchema = {
  "@context": "https://schema.org",
  "@type": schemaType,
  name: derivedSchemaName,
  url: canonicalUrl,
  description,
};

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Deepak Gupta",
  jobTitle: "Principal",
  worksFor: {
    "@type": "Organization",
    name: "Autonomy Bridge",
    url: siteUrl,
  },
  sameAs: ["https://www.linkedin.com/in/deepakgupta5"],
  knowsAbout: [
    "warehouse robotics",
    "AMR deployment",
    "automation ROI",
    "robotics deployment economics",
    "warehouse automation failure analysis",
    "vendor economics",
    "deployment risk assessment",
    "3PL warehouse automation",
    "goods-to-person systems",
    "robotics-as-a-service",
  ],
};

const articleSchema = articleData ? {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: articleData.title,
  description: articleData.description,
  datePublished: articleData.pubDate instanceof Date
    ? articleData.pubDate.toISOString()
    : articleData.pubDate,
  author: { "@type": "Person", name: "Deepak Gupta" },
  publisher: {
    "@type": "Organization",
    name: "Autonomy Bridge",
    url: siteUrl,
  },
  mainEntityOfPage: canonicalUrl,
} : null;

const faqSchema = faqData && faqData.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqData.map((item: { question: string; answer: string }) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: { "@type": "Answer", text: item.answer },
  })),
} : null;

const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbs.map((crumb: { name: string; url: string }, i: number) => ({
    "@type": "ListItem",
    position: i + 1,
    name: crumb.name,
    item: crumb.url,
  })),
} : null;

const definedTermSchema = definedTermData ? {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  name: definedTermData.name,
  description: definedTermData.description,
  inDefinedTermSet: {
    "@type": "DefinedTermSet",
    name: "Warehouse Automation Glossary",
    url: `${siteUrl}/glossary`,
  },
} : null;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" href="/favicon.svg" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@600;700&family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://www.autonomybridge.com/og-image.png" />
  <meta property="og:type" content={articleData ? "article" : "website"} />
  <meta property="og:url" content={canonicalUrl} />
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Schema: always present -->
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)}></script>
  {includePageSchema && !articleData && !serviceSchema && <script type="application/ld+json" set:html={JSON.stringify(pageSchema)}></script>}

  <!-- Schema: conditional -->
  {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>}
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>}
  {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)}></script>}
  {serviceSchema && <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>}
  {definedTermSchema && <script type="application/ld+json" set:html={JSON.stringify(definedTermSchema)}></script>}

  <slot name="head" />
</head>
<body>
  <slot />
  <!-- Netlify Forms registration — required for build bot detection with Astro -->
  <form name="contact" netlify netlify-honeypot="bot-field" hidden>
    <input type="text" name="name" />
    <input type="email" name="email" />
    <input type="text" name="company" />
    <input type="text" name="subject" />
    <textarea name="message"></textarea>
  </form>
</body>
</html>
