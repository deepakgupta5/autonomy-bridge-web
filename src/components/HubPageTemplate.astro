---
import type { HubPageContent } from "../data/hubContent";
import MainLayout from "./MainLayout.astro";
import ContentCard from "./ContentCard.astro";
import { getHubAssetSurfacing } from "../utils/relatedContent";
import {
  buildCollectionPageSchema,
  buildFaqPageSchema,
  type FaqSchemaItem,
} from "../utils/schema";

interface Props {
  canonicalPath: string;
  content: HubPageContent;
  faqItems?: FaqSchemaItem[];
}

const { canonicalPath, content, faqItems = [] } = Astro.props;
const hasItems = content.items.length > 0;

const ctaText = canonicalPath.startsWith("/frameworks")
  ? "Apply these frameworks to your deployment decision."
  : canonicalPath.startsWith("/use-cases")
  ? "See how these use cases apply to your operation."
  : canonicalPath.startsWith("/case-studies")
  ? "Apply these findings to your deployment decision."
  : "Apply this research to your deployment decision.";
const surfacedAssets = getHubAssetSurfacing(canonicalPath, 12);
const pageSchema = [
  buildCollectionPageSchema({
    name: content.title,
    description: content.summary,
    canonicalPath,
  }),
];
const faqSchema = buildFaqPageSchema({
  canonicalPath,
  items: faqItems,
});
const schema = faqSchema ? [...pageSchema, faqSchema] : pageSchema;
---

<MainLayout
  title={content.title}
  summary={content.summary}
  canonicalPath={canonicalPath}
  schema={schema}
>
  <section class="hub-intro">
    <h1 class="type-h1">{content.title}</h1>
    <p class="hub-tagline">{content.intro}</p>
  </section>

  {
    hasItems ? (
      <section class="hub-grid" aria-label={`${content.title} entries`}>
        {content.items.map((item) => <ContentCard item={item} />)}
      </section>
    ) : (
      <section class="hub-empty">
        <p class="type-body">{content.emptyState}</p>
      </section>
    )
  }

  <section class="hub-cta">
    <p class="hub-cta-text">{ctaText}</p>
    <a href="/contact" class="hub-cta-link">Book 15-min scoping call</a>
  </section>

  <section class="hub-body prose-surface">
    <slot />
  </section>

  {
    surfacedAssets.length > 0 && (
      <nav class="hub-surfacing" aria-label="Jump to section">
        <p class="hub-surfacing-label">Jump to framework</p>
        <ul class="hub-surfacing-pills">
          {surfacedAssets.map((asset) => (
            <li>
              <a href={asset.canonicalPath}>{asset.title}</a>
            </li>
          ))}
        </ul>
      </nav>
    )
  }
</MainLayout>

<script>
  // ── Hub body cleanup ─────────────────────────────────────────────────────
  // Hub markdown bodies often open with an H2 that repeats the page H1 title,
  // and contain an "X Index" H2 section that duplicates the card grid below.
  // Both are redundant with the server-rendered hero + hub-grid — hide them.
  const hubBody = document.querySelector(".hub-body");
  if (hubBody) {
    // 1. Hide first H2 if its text matches or is a prefix of the page H1
    //    (e.g. H1 "X — Autonomy Bridge" vs H2 "X")
    const pageH1Text = document.querySelector(".hub-intro h1")?.textContent?.trim() ?? "";
    const firstH2 = hubBody.querySelector("h2");
    const firstH2Text = firstH2?.textContent?.trim() ?? "";
    if (firstH2 && pageH1Text && (firstH2Text === pageH1Text || pageH1Text.startsWith(firstH2Text))) {
      firstH2.style.display = "none";
    }

    // 2. Hide H2s whose text ends with "Index" and all their following siblings
    //    until the next H2 (which starts the next real section).
    let inIndex = false;
    Array.from(hubBody.children).forEach((child) => {
      const tag = child.tagName ?? "";
      const text = (child.textContent ?? "").trim();
      if (tag === "H2") {
        if (text.endsWith("Index")) {
          inIndex = true;
          child.style.display = "none";
          return;
        }
        // A new H2 that is NOT an index header closes the suppression window
        if (inIndex) { inIndex = false; return; }
      }
      if (inIndex) { child.style.display = "none"; }
    });

    // 3. Hide cross-hub nav paragraphs (e.g. "Home · Market Overview · Glossary")
    hubBody.querySelectorAll("p").forEach((p) => {
      const txt = (p.textContent ?? "").trim();
      if (/^Home\s*·/.test(txt)) { p.style.display = "none"; }
    });

    // 5. Hide editorial H2 sections that are redundant with the page layout:
    //    "How to Use the Frameworks" (info covered by card grid + tagline)
    //    "Related Resources" (info covered by hub-surfacing pills)
    //    Hide the H2 and all following siblings until the next H2 or HR.
    const HIDDEN_SECTIONS = ["how to use", "related resources"];
    let inHiddenSection = false;
    Array.from(hubBody.children).forEach((child) => {
      const tag = child.tagName ?? "";
      const text = (child.textContent ?? "").trim().toLowerCase();
      if (tag === "H2") {
        if (HIDDEN_SECTIONS.some((s) => text.startsWith(s))) {
          inHiddenSection = true;
          child.style.display = "none";
          return;
        }
        inHiddenSection = false;
      }
      if (tag === "HR") { inHiddenSection = false; }
      if (inHiddenSection) { (child as HTMLElement).style.display = "none"; }
    });

    // 4. Structure FAQ Q&A pairs (same pattern as detail page Transform 7)
    let inFaq = false;
    Array.from(hubBody.children).forEach((child) => {
      const tag = child.tagName ?? "";
      const text = (child.textContent ?? "").trim();
      if (tag === "H2" && text.toLowerCase().startsWith("frequently asked")) {
        inFaq = true;
        return;
      }
      if (tag === "H2" && inFaq) { inFaq = false; return; }
      if (!inFaq || tag !== "P") return;

      const firstEl = child.firstElementChild;
      if (!firstEl || firstEl.tagName !== "STRONG") return;

      const wrapper = document.createElement("div");
      wrapper.className = "faq-qa-pair";

      const qEl = document.createElement("div");
      qEl.className = "faq-q";
      qEl.textContent = firstEl.textContent ?? "";

      const aEl = document.createElement("div");
      aEl.className = "faq-a";

      let afterStrong = false;
      child.childNodes.forEach((node) => {
        if (afterStrong) {
          if (node.nodeType === Node.TEXT_NODE) {
            aEl.appendChild(document.createTextNode(node.textContent ?? ""));
          } else if (node.nodeType === Node.ELEMENT_NODE) {
            aEl.appendChild(node.cloneNode(true));
          }
        }
        if (node === firstEl) afterStrong = true;
      });

      wrapper.appendChild(qEl);
      if (aEl.textContent?.trim()) wrapper.appendChild(aEl);
      child.replaceWith(wrapper);
    });
  }
</script>

<style>
  /* ── Hero ──────────────────────────────────── */
  .hub-intro {
    padding-top: 0.5rem;
    margin-bottom: 2rem;
  }

  .hub-intro :global(h1) {
    margin: 0 0 0.85rem;
  }

  .hub-tagline {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 58ch;
  }

  /* ── Prose body ─────────────────────────────── */
  .hub-body {
    margin-bottom: 2.5rem;
    background: transparent;
  }

  /* Visual separator between major H2 blocks inside hub-body prose */
  .hub-body :global(h2) {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border-light);
  }

  .hub-body :global(h2:first-child) {
    border-top: none;
    padding-top: 0;
    margin-top: 1rem;
  }

  /* FAQ Q&A pairs */
  .hub-body :global(.faq-qa-pair) {
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-border-light);
  }

  .hub-body :global(.faq-qa-pair:first-of-type) {
    border-top: none;
    padding-top: 0;
  }

  .hub-body :global(.faq-q) {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
    line-height: 1.45;
  }

  .hub-body :global(.faq-a) {
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  /* ── Quick-jump pills ───────────────────────── */
  .hub-surfacing {
    margin-bottom: 2rem;
  }

  .hub-surfacing-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin: 0 0 0.65rem;
  }

  .hub-surfacing-pills {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .hub-surfacing-pills a {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--color-border-default);
    border-radius: 999px;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    background: var(--color-bg-page);
    transition: border-color 0.15s, color 0.15s;
  }

  .hub-surfacing-pills a:hover {
    border-color: var(--color-border-accent);
    color: var(--color-text-accent);
  }

  /* ── Dark CTA banner ────────────────────────── */
  .hub-cta {
    background: var(--color-cta-bg);
    border-top: 3px solid var(--color-cta-border);
    border-radius: 6px;
    padding: 1.75rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .hub-cta-text {
    color: var(--color-cta-text);
    font-size: var(--text-base);
    opacity: 0.85;
    margin: 0;
  }

  .hub-cta-link {
    display: inline-block;
    border: 1px solid var(--color-cta-border);
    color: var(--color-cta-text);
    padding: 0.55rem 1.25rem;
    border-radius: 4px;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .hub-cta-link:hover {
    background: rgba(217, 119, 6, 0.15);
  }

  /* ── Card grid ──────────────────────────────── */
  .hub-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }

  /* ── Empty state ────────────────────────────── */
  .hub-empty {
    border: 0.0625rem dashed var(--color-border-default);
    border-radius: 0.65rem;
    background: var(--color-bg-page);
    padding: 1rem;
  }
</style>
