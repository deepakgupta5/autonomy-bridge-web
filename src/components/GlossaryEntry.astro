---
const { title, abbreviation, definition, relatedTerms, usedIn } = Astro.props;
---
<div class="glossary-entry">
  <h1>{title}{abbreviation ? ` (${abbreviation})` : ''}</h1>
  <p class="glossary-entry__definition">{definition}</p>

  {usedIn && usedIn.length > 0 && (
    <p class="glossary-entry__used-in small-text">
      Used in: {usedIn.map((slug: string, i: number) => (
        <span>
          <a href={`/insights/${slug}`}>{slug.replace(/-/g, ' ')}</a>
          {i < usedIn.length - 1 ? ', ' : ''}
        </span>
      ))}
    </p>
  )}

  {relatedTerms && relatedTerms.length > 0 && (
    <p class="glossary-entry__related small-text">
      Related terms: {relatedTerms.map((slug: string, i: number) => (
        <span>
          <a href={`/glossary/${slug}`}>{slug.replace(/-/g, ' ')}</a>
          {i < relatedTerms.length - 1 ? ', ' : ''}
        </span>
      ))}
    </p>
  )}
</div>

<style>
.glossary-entry__definition {
  font-size: 17px;
  line-height: 1.65;
  max-width: 75ch;
  margin-bottom: 16px;
}
.glossary-entry__used-in,
.glossary-entry__related {
  max-width: none;
  margin-bottom: 8px;
}
.glossary-entry__used-in a,
.glossary-entry__related a {
  color: var(--accent);
  text-decoration: none;
}
.glossary-entry__used-in a:hover,
.glossary-entry__related a:hover {
  text-decoration: underline;
}
</style>
