---
import MainLayout from "./MainLayout.astro";
import type { DiagramAsset } from "../data/diagramAssetMap";
import { getRelatedContentContext } from "../utils/relatedContent";
import {
  buildArticleSchema,
  buildCaseStudySchema,
  buildFaqPageSchema,
  buildUseCaseSchema,
  type FaqSchemaItem,
} from "../utils/schema";

interface Props {
  canonicalPath: string;
  title: string;
  summary: string;
  contentTypeLabel: string;
  slug: string;
  hubPath: string;
  hubLabel: string;
  diagrams?: DiagramAsset[];
  schemaKind: "framework" | "insight" | "useCase" | "caseStudy";
  faqItems?: FaqSchemaItem[];
  datePublished?: string;
  dateModified?: string;
  authors?: string[];
}

const {
  canonicalPath,
  title,
  summary,
  contentTypeLabel,
  slug,
  hubPath,
  hubLabel,
  diagrams = [],
  schemaKind,
  faqItems = [],
  datePublished,
  dateModified,
  authors,
} = Astro.props;

const relatedContext = getRelatedContentContext(canonicalPath, {
  lateralLimit: 12,
  semanticLimit: 8,
});
const resolvedHubPath = relatedContext.upwardHub?.canonicalPath ?? hubPath;
const resolvedHubLabel = relatedContext.upwardHub?.title ?? hubLabel;
const schemaByKind = {
  framework: buildArticleSchema({
    title,
    description: summary,
    canonicalPath,
    articleType: "Article",
    datePublished,
    dateModified,
    authors,
  }),
  insight: buildArticleSchema({
    title,
    description: summary,
    canonicalPath,
    articleType: "Article",
    datePublished,
    dateModified,
    authors,
  }),
  useCase: buildUseCaseSchema({
    title,
    description: summary,
    canonicalPath,
    schemaType: "TechArticle",
    datePublished,
    dateModified,
    authors,
  }),
  caseStudy: buildCaseStudySchema({
    title,
    description: summary,
    canonicalPath,
    datePublished,
    dateModified,
    authors,
  }),
} as const;

const detailSchema = schemaByKind[schemaKind];
const faqSchema = buildFaqPageSchema({
  canonicalPath,
  items: faqItems,
});
const schema = faqSchema ? [detailSchema, faqSchema] : [detailSchema];
---

<MainLayout title={title} summary={summary} canonicalPath={canonicalPath} schema={schema}>
  <article class="prose-surface detail-template">

    <!-- ── Hero header ─────────────────────────── -->
    <header class="detail-header">
      <p class="detail-eyebrow type-eyebrow">{contentTypeLabel}</p>
      <h1 class="type-h1">{title}</h1>
      <p class="detail-tagline">{summary}</p>
    </header>

    <!-- ── Body prose ────────────────────────────── -->
    <!-- Diagrams are injected inline by the client script below -->
    <section class="detail-body prose-surface">
      <slot />
    </section>

    <!-- ── Dark CTA banner ───────────────────────── -->
    <section class="detail-cta">
      <p class="detail-cta-text">
        {schemaKind === "framework"
          ? "Apply this framework to your deployment decision."
          : schemaKind === "caseStudy"
          ? "Apply these findings to your deployment decision."
          : "Apply this research to your deployment decision."}
      </p>
      <div class="detail-cta-actions">
        {schemaKind === "caseStudy" && (
          <a href="/advisory" class="detail-cta-secondary">See advisory scope →</a>
        )}
        <a href="/contact" class="detail-cta-link">Book 15-min scoping call</a>
      </div>
    </section>

    <!-- ── Related content ──────────────────────── -->
    {
      relatedContext.lateralRelated.length > 0 && (
        <section class="related-content">
          <h2 class="type-h2">Related Content</h2>
          <ul class="related-pills">
            {relatedContext.lateralRelated.map((link) => (
              <li>
                <a href={link.canonicalPath}>{link.title}</a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <!-- ── Semantic links ────────────────────────── -->
    {
      (relatedContext.semanticFrameworkLinks.length > 0 ||
        relatedContext.semanticGlossaryLinks.length > 0) && (
        <section class="semantic-links">
          {relatedContext.semanticFrameworkLinks.length > 0 && (
            <>
              <h2 class="type-h2">Related Frameworks</h2>
              <ul class="related-pills">
                {relatedContext.semanticFrameworkLinks.map((link) => (
                  <li>
                    <a href={link.canonicalPath}>{link.title}</a>
                  </li>
                ))}
              </ul>
            </>
          )}
          {relatedContext.semanticGlossaryLinks.length > 0 && (
            <>
              <h2 class="type-h2">Related Glossary Terms</h2>
              <ul class="related-pills">
                {relatedContext.semanticGlossaryLinks.map((link) => (
                  <li>
                    <a href={link.canonicalPath}>{link.title}</a>
                  </li>
                ))}
              </ul>
            </>
          )}
        </section>
      )
    }
  </article>
</MainLayout>

<!--
  Client-side content transforms:
  1. Strip {#anchor-id} text rendered literally by markdown parser
  2. Replace [NO VISIBLE IMAGE] placeholders with actual inline figures
  3. Hide Appendix sections (build-time metadata not intended for display)
-->
<script define:vars={{ diagrams }}>
  const body = document.querySelector(".detail-body");
  if (!body) return;

  // ── 1. Strip {#anchor} text from all headings ──────────────────────────
  body.querySelectorAll("h1, h2, h3, h4, h5").forEach((heading) => {
    heading.childNodes.forEach((node) => {
      if (node.nodeType === Node.TEXT_NODE) {
        node.textContent = node.textContent?.replace(/\s*\{#[^}]+\}$/, "") ?? "";
      }
    });
  });

  // ── 2. Inline diagrams at [NO VISIBLE IMAGE] positions ─────────────────
  // Build a map: fig_1 → diagram, fig_2 → diagram, ...
  const figMap = new Map(
    diagrams.map((d) => [`fig_${d.diagramOrder}`, d])
  );

  body.querySelectorAll("p").forEach((p) => {
    const text = p.textContent?.trim() ?? "";
    if (!text.startsWith("[NO VISIBLE IMAGE")) return;

    const match = text.match(/\bfig_(\d+)\b/i);
    if (match) {
      const figKey = `fig_${match[1]}`;
      const diagram = figMap.get(figKey);
      if (diagram) {
        const figure = document.createElement("figure");
        figure.className = "inline-diagram";

        const img = document.createElement("img");
        img.src = diagram.publicPath;
        img.alt = diagram.caption;
        img.width = diagram.width;
        img.height = diagram.height;
        img.loading = "lazy";
        img.decoding = "async";

        const caption = document.createElement("figcaption");
        caption.className = "type-caption";
        caption.textContent = diagram.caption;

        figure.appendChild(img);
        figure.appendChild(caption);
        p.replaceWith(figure);
      } else {
        // Diagram data not found — hide the placeholder
        p.style.display = "none";
      }
    } else {
      // No fig_N match — hide the placeholder
      p.style.display = "none";
    }
  });

  // ── 3. Hide Appendix sections (build-time metadata) ────────────────────
  // Walk children: once we hit an H2 whose text starts with "Appendix", hide
  // it and all following siblings to the end of the body.
  let appendixFound = false;
  Array.from(body.children).forEach((child) => {
    if (appendixFound) {
      child.style.display = "none";
      return;
    }
    if (
      child.tagName === "H2" &&
      child.textContent?.trim().startsWith("Appendix")
    ) {
      appendixFound = true;
      child.style.display = "none";
    }
  });

  // ── 5. Hide duplicate H1 (markdown title duplicates hero) ─────────────────
  // The markdown body often starts with # Title {#anchor}. After transform 1
  // strips the anchor text, the H1 still duplicates the hero heading.
  const firstBodyH1 = body.querySelector("h1");
  if (firstBodyH1) {
    firstBodyH1.style.display = "none";
  }

  // ── 6. Hide :::directive::: blocks ─────────────────────────────────────
  // Handles :::ai-contract, :::hard-truth, :::logic-block etc.
  // Some blocks are self-contained (one paragraph). Others have list items
  // that the markdown parser breaks into a <ul>, so we track open/close.
  let inDirective = false;
  Array.from(body.children).forEach((child) => {
    const txt = (child.textContent ?? "").trim();
    const isOpeningDirective = child.tagName === "P" && /^:::[a-z]/.test(txt);
    const isClosingDirective = child.tagName === "P" && txt === ":::";

    if (inDirective) {
      child.style.display = "none";
      if (isClosingDirective) inDirective = false;
      return;
    }

    if (isOpeningDirective) {
      child.style.display = "none";
      // Self-contained if the paragraph already ends with ::: (no breakout children).
      // Otherwise track until we hit the standalone ::: closing paragraph.
      if (!txt.endsWith(":::")) inDirective = true;
      return;
    }
  });

  // ── 7. Structure FAQ Q&A pairs ──────────────────────────────────────────
  // Markdown FAQ format: **Question?** followed by answer text in the same <p>.
  // Find the FAQ H2, then wrap each bold-question paragraph as a styled pair.
  let inFaq = false;
  Array.from(body.children).forEach((child) => {
    const tag = child.tagName;
    const text = child.textContent?.trim() ?? "";

    if (tag === "H2" && text.toLowerCase().startsWith("frequently asked")) {
      inFaq = true;
      return;
    }
    if (tag === "H2" && inFaq) {
      inFaq = false;
      return;
    }
    if (!inFaq || tag !== "P") return;

    // Check if first child is <strong> (the question)
    const firstEl = child.firstElementChild;
    if (!firstEl || firstEl.tagName !== "STRONG") return;

    const wrapper = document.createElement("div");
    wrapper.className = "faq-qa-pair";

    const qEl = document.createElement("div");
    qEl.className = "faq-q";
    qEl.textContent = firstEl.textContent ?? "";

    const aEl = document.createElement("div");
    aEl.className = "faq-a";

    // Collect everything after the <strong> in this paragraph
    let afterStrong = false;
    child.childNodes.forEach((node) => {
      if (afterStrong) {
        if (node.nodeType === Node.TEXT_NODE) {
          aEl.appendChild(document.createTextNode(node.textContent ?? ""));
        } else if (node.nodeType === Node.ELEMENT_NODE) {
          aEl.appendChild(node.cloneNode(true));
        }
      }
      if (node === firstEl) afterStrong = true;
    });

    wrapper.appendChild(qEl);
    if (aEl.textContent?.trim()) wrapper.appendChild(aEl);
    child.replaceWith(wrapper);
  });

  // ── 8. Hide hub back-link and related-list paragraphs ───────────────────
  // Hides: "[All Insights →]", "**Framework hub:** ...", and inline "Related
  // case studies:", "Related frameworks:", "Glossary terms:" link paragraphs
  // that are redundant with the structured Related Content / pill nav.
  body.querySelectorAll("p").forEach((p) => {
    const txt = (p.textContent ?? "").trim();
    if (/^All .+ →$/.test(txt)) { p.style.display = "none"; return; }
    if (/^(Framework|Insights|Use Cases|Case Studies) hub:/.test(txt)) { p.style.display = "none"; return; }
    if (/^(Related case studies|Related frameworks|Related insights|Related use cases?|Glossary terms?):/.test(txt)) { p.style.display = "none"; }
  });

  // ── 9. Hide JSON-LD code blocks (schema.org data embedded in markdown) ───
  // Case study (and some other) markdown files embed a ```json schema block
  // at the bottom. The server already builds structured data in <head>;
  // the markdown version renders as a visible <pre> — hide it.
  body.querySelectorAll("pre").forEach((pre) => {
    const text = (pre.textContent ?? "").trim();
    if (text.startsWith("{") && text.includes('"@context"')) {
      pre.style.display = "none";
    }
  });

  // ── 4. Style "(Autonomy Bridge proprietary analysis, ...)" citations ─────
  const CITATION_RE = /(\(Autonomy Bridge proprietary analysis[^)]*\))/g;

  function wrapCitationsInNode(node) {
    if (node.nodeType === Node.TEXT_NODE) {
      const text = node.textContent ?? "";
      if (!CITATION_RE.test(text)) return;
      CITATION_RE.lastIndex = 0;
      const parts = [];
      let lastIndex = 0;
      let match;
      while ((match = CITATION_RE.exec(text)) !== null) {
        if (match.index > lastIndex) {
          parts.push(document.createTextNode(text.slice(lastIndex, match.index)));
        }
        const cite = document.createElement("cite");
        cite.className = "ab-citation";
        cite.textContent = match[1];
        parts.push(cite);
        lastIndex = match.index + match[0].length;
      }
      if (lastIndex < text.length) {
        parts.push(document.createTextNode(text.slice(lastIndex)));
      }
      const frag = document.createDocumentFragment();
      parts.forEach((p) => frag.appendChild(p));
      node.replaceWith(frag);
    } else if (node.nodeType === Node.ELEMENT_NODE && node.nodeName !== "SCRIPT" && node.nodeName !== "STYLE") {
      Array.from(node.childNodes).forEach(wrapCitationsInNode);
    }
  }

  wrapCitationsInNode(body);
</script>

<style>
  /* ── Layout ──────────────────────────────────── */
  .detail-template {
    max-width: 78ch;
    margin-inline: auto;
  }

  .detail-template section + section {
    margin-top: 2.5rem;
  }

  /* ── Hero header ─────────────────────────────── */
  .detail-header {
    padding: 0.5rem 0 2rem;
    border-bottom: 0.0625rem solid var(--color-border-light);
    margin-bottom: 0.5rem;
  }

  .detail-eyebrow {
    color: var(--color-text-accent);
    margin: 0 0 0.6rem;
    letter-spacing: 0.08em;
  }

  .detail-header :global(h1) {
    margin: 0 0 0.85rem;
    line-height: 1.25;
  }

  .detail-tagline {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 62ch;
  }

  /* ── Inline diagrams (injected by script) ────── */
  .detail-body :global(.inline-diagram) {
    margin: 2rem 0;
    border: 1px solid var(--color-border-light);
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-bg-page);
  }

  .detail-body :global(.inline-diagram img) {
    display: block;
    width: 100%;
    height: auto;
  }

  .detail-body :global(.inline-diagram figcaption) {
    padding: 0.5rem 0.75rem;
    background: var(--color-bg-surface);
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border-light);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  /* ── Dark CTA banner ─────────────────────────── */
  .detail-cta {
    background: var(--color-cta-bg);
    border-top: 3px solid var(--color-cta-border);
    border-radius: 6px;
    padding: 1.75rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .detail-cta-text {
    color: var(--color-cta-text);
    font-size: var(--text-base);
    opacity: 0.85;
    margin: 0;
  }

  .detail-cta-link {
    display: inline-block;
    border: 1px solid var(--color-cta-border);
    color: var(--color-cta-text);
    padding: 0.55rem 1.25rem;
    border-radius: 4px;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .detail-cta-link:hover {
    background: rgba(217, 119, 6, 0.15);
  }

  .detail-cta-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .detail-cta-secondary {
    font-size: var(--text-sm);
    color: var(--color-cta-text);
    opacity: 0.7;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.15s;
  }

  .detail-cta-secondary:hover {
    opacity: 1;
  }

  /* ── Related / semantic pills ────────────────── */
  .related-pills {
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .related-pills a {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    border: 1px solid var(--color-border-default);
    border-radius: 999px;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    background: var(--color-bg-page);
    transition: border-color 0.15s, color 0.15s;
  }

  .related-pills a:hover {
    border-color: var(--color-border-accent);
    color: var(--color-text-accent);
  }

  /* ── Detail body prose overrides ─────────────── */

  /* Blockquotes → amber callout (Key Finding) */
  .detail-body :global(blockquote) {
    border-left: 0.25rem solid var(--color-border-accent);
    background: var(--color-bg-accent);
    padding: 1rem 1.25rem;
    border-radius: 0 4px 4px 0;
    margin: 1.5rem 0;
  }

  /* Code blocks → formula / machine-logic display */
  .detail-body :global(pre) {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-light);
    border-left: 3px solid var(--color-border-default);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.65;
    margin: 1.25rem 0;
  }

  .detail-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: inherit;
  }

  /* Tables → readable padding + monospace headers */
  .detail-body :global(th) {
    background: var(--color-bg-surface);
    font-weight: var(--weight-semibold);
    padding: 0.65rem 0.85rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .detail-body :global(td) {
    padding: 0.6rem 0.85rem;
    vertical-align: top;
  }

  /* HR separators */
  .detail-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border-light);
    margin: 2.5rem 0;
  }

  /* Heading spacing inside body */
  .detail-body :global(h2) {
    margin-top: 2.5rem;
  }

  .detail-body :global(h3) {
    margin-top: 1.75rem;
  }

  /* List item spacing */
  .detail-body :global(li + li) {
    margin-top: 0.5rem;
  }

  /* FAQ Q&A pairs */
  .detail-body :global(.faq-qa-pair) {
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-border-light);
  }

  .detail-body :global(.faq-qa-pair:last-of-type) {
    padding-bottom: 0;
  }

  .detail-body :global(.faq-q) {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
    line-height: 1.45;
  }

  .detail-body :global(.faq-a) {
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  /* Proprietary analysis citations */
  .detail-body :global(.ab-citation) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    font-style: normal;
    letter-spacing: 0.01em;
  }
</style>
