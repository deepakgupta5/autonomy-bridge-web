---
import MainLayout from "./MainLayout.astro";

interface Props {
  canonicalPath: string;
  title: string;
  summary: string;
  seoTitle?: string;
  seoDescription?: string;
  keywords?: string[];
  robots?: string;
  showHeader?: boolean;
}

const {
  canonicalPath,
  title,
  summary,
  seoTitle,
  seoDescription,
  keywords,
  robots,
  showHeader = true,
} = Astro.props;
---

<MainLayout
  title={title}
  summary={summary}
  canonicalPath={canonicalPath}
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  keywords={keywords}
  robots={robots}
>
  <article class="prose-surface legal-page-template">
    {
      showHeader && (
        <header class="legal-page-header">
          <h1 class="type-h1">{title}</h1>
          <p class="type-body prose-intro">{summary}</p>
        </header>
      )
    }

    <section class:list={["legal-page-body prose-surface", showHeader ? "with-header" : "without-header"]}>
      <slot />
    </section>
  </article>
</MainLayout>

<style>
  .legal-page-template {
    max-width: 78ch;
    margin-inline: auto;
  }

  .legal-page-header {
    border: 0.0625rem solid #d1d5db;
    border-radius: 0.625rem;
    background: #ffffff;
    padding: 1rem;
  }

  .legal-page-header h1,
  .legal-page-header p {
    margin: 0;
  }

  .legal-page-header p + p {
    margin-top: 0.55rem;
  }

  .legal-page-template section + section {
    margin-top: 1.5rem;
  }

  .legal-page-body {
    margin-top: 1.5rem;
  }

  .legal-page-body.without-header {
    margin-top: 0;
  }

  .legal-page-body h1 {
    margin-top: 0;
    margin-bottom: 0.5rem;
  }

  .legal-page-body > p:first-of-type {
    margin-top: 0;
    font-size: var(--role-meta-size);
    line-height: var(--role-tight-line);
    color: #4b5563;
  }
</style>
