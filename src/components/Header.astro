---
import { primaryNavItems } from "../data/ia";
import { normalizePathname } from "../utils/navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const normalizedCurrentPath = normalizePathname(currentPath);

function isActive(href: string): boolean {
  if (href === "/") {
    return normalizedCurrentPath === "/";
  }
  return normalizedCurrentPath === href || normalizedCurrentPath.startsWith(`${href}/`);
}
---

<header class="site-header">
  <div class="site-header-inner">
    <a class="site-brand" href="/">
      <span class="brand-badge">AB</span>
      <span class="brand-divider" aria-hidden="true"></span>
      <span class="brand-text">
        <span class="brand-name">Autonomy Bridge</span>
        <span class="brand-tagline">Robotics Deployment Economics</span>
      </span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      {
        primaryNavItems.map((item) => (
          <a
            href={item.href}
            class="type-body-sm"
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <a href="/contact" class="header-cta">Book 15-min call</a>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 0.0625rem solid var(--color-border-light);
    background: #ffffff;
  }

  .site-header-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1rem;
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
  }

  .site-brand {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .brand-badge {
    width: 2.1rem;
    height: 2.1rem;
    border: 1.5px solid var(--color-text-primary);
    border-radius: 0.3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-text-primary);
    flex-shrink: 0;
  }

  .brand-divider {
    width: 2px;
    height: 1.875rem;
    background: var(--color-border-accent);
    flex-shrink: 0;
  }

  .brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .brand-name {
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    line-height: 1;
  }

  .brand-tagline {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .site-nav {
    display: flex;
    gap: 0.25rem 0.75rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .site-nav a {
    color: var(--color-text-secondary);
    text-decoration: none;
    white-space: nowrap;
  }

  .site-nav a[aria-current="page"] {
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .header-cta {
    display: inline-block;
    white-space: nowrap;
    background: var(--color-cta-bg);
    color: var(--color-cta-text);
    border: 1.5px solid var(--color-cta-border);
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1;
    padding: 0.5rem 0.9rem;
    border-radius: 0.375rem;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }

  .header-cta:hover {
    background: var(--color-border-strong);
    border-color: var(--color-cta-border);
  }

  @media (max-width: 60rem) {
    .site-header-inner {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.75rem;
    }

    .site-nav {
      width: 100%;
      justify-content: flex-start;
      gap: 0.25rem 1rem;
    }
  }
</style>
