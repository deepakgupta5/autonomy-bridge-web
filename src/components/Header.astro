---
import { primaryNavItems } from "../data/ia";
import { normalizePathname } from "../utils/navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const normalizedCurrentPath = normalizePathname(currentPath);

function isActive(href: string): boolean {
  if (href === "/") {
    return normalizedCurrentPath === "/";
  }
  return normalizedCurrentPath === href || normalizedCurrentPath.startsWith(`${href}/`);
}
---

<header class="site-header">
  <div class="site-header-inner">
    <a class="site-brand type-eyebrow" href="/">Autonomy Bridge</a>
    <nav class="site-nav" aria-label="Primary">
      {
        primaryNavItems.map((item) => (
          <a
            href={item.href}
            class="type-body-sm"
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 0.0625rem solid #e5e7eb;
    background: #ffffff;
  }

  .site-header-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1rem;
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
  }

  .site-brand {
    color: #111827;
    text-decoration: none;
    white-space: nowrap;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .site-nav {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .site-nav a {
    color: #1f2937;
    text-decoration: none;
  }

  .site-nav a[aria-current="page"] {
    font-weight: 700;
  }

  @media (max-width: 60rem) {
    .site-header-inner {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
