---
import MainLayout from "./MainLayout.astro";

interface Props {
  title: string;
  summary?: string;
}

const { title, summary = "" } = Astro.props;

function toCanonicalShellPath(pathname: string): string {
  if (!pathname || pathname === "/") {
    return "/";
  }

  const normalizedPath = pathname.endsWith("/") ? pathname.slice(0, -1) : pathname;

  if (normalizedPath === "/index.html") {
    return "/";
  }

  if (normalizedPath.endsWith("/index.html")) {
    const trimmed = normalizedPath.slice(0, -"/index.html".length);
    return trimmed || "/";
  }

  if (normalizedPath.endsWith(".html")) {
    const trimmed = normalizedPath.slice(0, -".html".length);
    return trimmed || "/";
  }

  return normalizedPath || "/";
}

const canonicalPath = toCanonicalShellPath(Astro.url.pathname);
---

<MainLayout title={title} summary={summary} canonicalPath={canonicalPath}>
  <section class="prose-surface shell-content">
    <h1 class="type-h1">{title}</h1>
    {summary && <p class="type-body prose-intro">{summary}</p>}
    <div class="shell-note type-meta">
      Route shell active. Full template/content wiring occurs in later blocks.
    </div>
    <slot />
  </section>
</MainLayout>

<style>
  .shell-content {
    max-width: 70ch;
    margin-inline: auto;
  }

  .shell-note {
    margin-top: 1.25rem;
    padding: 0.75rem 0.9rem;
    border: 0.0625rem solid #d1d5db;
    background: #ffffff;
    border-radius: 0.5rem;
  }
</style>
